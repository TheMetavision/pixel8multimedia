# ── Pixel8 Multimedia — Environment Variables ──
# Copy to .env and fill in values. Add all to Netlify dashboard > Site > Environment.

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_COMMISSION_WEBHOOK_SECRET=whsec_...

# Sanity (write token — for functions that create/patch commission docs)
SANITY_TOKEN=sk...

# Sanity Webhook (optional but recommended — GROQ webhook secret for commission-deliver)
SANITY_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=re_...

# Download link signing secret (generate with: openssl rand -hex 32)
DOWNLOAD_LINK_SECRET=

# Site URL (auto-set by Netlify, override for local dev)
URL=https://pixel8multimedia.co.uk
