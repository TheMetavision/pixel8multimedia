---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black border-t border-edge-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Centred Logo -->
    <div class="flex flex-col items-center mb-12">
      <a href="/">
        <img src="/Pixel8_Logo.png" alt="Pixel8 Multimedia — Pop. Art. Motion." class="h-[7.5rem] w-auto" />
      </a>
      <p class="font-dm text-sm text-mid-grey leading-relaxed mt-4 text-center max-w-md">
        Premium pop culture wall art and bespoke photo transformations. UK-based, delivering worldwide.
      </p>
      <div class="flex items-center gap-4 mt-4">
        <a href="https://facebook.com/pixel8multimedia" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-deep-grey hover:text-pop-orange transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <a href="https://instagram.com/pixel8multimedia" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-deep-grey hover:text-pop-orange transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://x.com/pixel8multi" target="_blank" rel="noopener noreferrer" aria-label="X" class="text-deep-grey hover:text-pop-orange transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.265 5.64 5.899-5.64zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://tiktok.com/@pixel8multimedia" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="text-deep-grey hover:text-pop-orange transition-colors">
          <svg class="w-4 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.02a8.16 8.16 0 004.77 1.52V7.1a4.85 4.85 0 01-1-.41z"/></svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Navigation -->
      <div>
        <h4 class="font-montserrat font-bold text-sm text-off-white uppercase tracking-wider mb-4">Navigation</h4>
        <ul class="space-y-2">
          <li><a href="/" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Home</a></li>
          <li><a href="/about" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">About Us</a></li>
          <li><a href="/store" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Shop Collections</a></li>
          <li><a href="/blog" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Blog</a></li>
          <li><a href="/contact" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Services & Legal -->
      <div>
        <h4 class="font-montserrat font-bold text-sm text-off-white uppercase tracking-wider mb-4">Services</h4>
        <ul class="space-y-2 mb-8">
          <li><a href="/services/cartoonify-me" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Cartoonify Me!</a></li>
          <li><a href="/services/stills-to-reels" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Stills to Reels</a></li>
          <li><a href="/services/the-missing-moment" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">The Missing Moment</a></li>
          <li><a href="/services/past-perfect" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Past Perfect</a></li>
          <li><a href="/services" class="font-dm text-sm text-pop-orange hover:underline transition-colors">View All Services →</a></li>
        </ul>
        <h4 class="font-montserrat font-bold text-sm text-off-white uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-2">
          <li><a href="/shipping-policy" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Shipping Info</a></li>
          <li><a href="/refund-policy" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Returns Policy</a></li>
          <li><a href="/terms-and-conditions" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Terms & Conditions</a></li>
          <li><a href="/privacy-policy" class="font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">Privacy Policy</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="font-montserrat font-bold text-sm text-off-white uppercase tracking-wider mb-4">Stay in the Loop</h4>
        <p class="font-dm text-sm text-mid-grey mb-4">New drops, exclusive collections, and pop culture inspiration — straight to your inbox.</p>
        <form class="flex flex-col gap-2" onsubmit="return false;">
          <input
            type="email"
            placeholder="your@email.com"
            class="bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-2.5 focus:outline-none focus:border-pop-orange transition-colors rounded"
            aria-label="Email address"
          />
          <button type="submit" class="btn-primary text-xs py-2.5">Subscribe</button>
        </form>
        <p class="font-dm text-xs text-deep-grey mt-2">No spam, ever. Unsubscribe any time.</p>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-edge-line mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-center md:text-left">
        <p class="font-dm text-xs text-deep-grey">&copy; {currentYear} Pixel8 Multimedia. All rights reserved.</p>
        <p class="font-dm text-xs text-deep-grey mt-1">
          Part of <a href="https://themetavision.co.uk" target="_blank" rel="noopener noreferrer" class="text-pop-orange hover:underline">The Metavision</a>
        </p>
      </div>
      <div class="flex items-center gap-4">
        <span class="font-mono text-[0.65rem] text-deep-grey border border-edge-line px-3 py-1 rounded uppercase tracking-wider">UK Made</span>
        <span class="font-mono text-[0.65rem] text-deep-grey border border-edge-line px-3 py-1 rounded uppercase tracking-wider">Worldwide Delivery</span>
      </div>
    </div>
  </div>
</footer>
