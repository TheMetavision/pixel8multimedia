---
// src/components/PricingStrip.astro
// Displays a pricing summary above the "How It Works" section on a service page.
// Mirrors the wizard's path picker:
//   - Digital Bundle (when service.digitalPrice set)
//   - Single Print (when service.printUpcharges has values)
//   - Bundle + Prints (when both Digital and Print available)
//   - Animation (Music) (when service.animationMusicPrice set)
//   - Animation (Music + VO) (when service.animationVoPrice set)
//
// Only renders if at least one pricing field is set.

interface Props {
  service: {
    digitalPrice?: number;
    digitalPriceSecondary?: number;
    digitalPriceBoth?: number;
    collectionLabel?: string;
    collectionLabelSecondary?: string;
    animationMusicPrice?: number;
    animationVoPrice?: number;
    artworkFee?: number;
    artworkBundledWithDigital?: boolean;
    artworkFeePerOrder?: boolean;
    printUpcharges?: {
      poster?: { small?: number; medium?: number; large?: number };
      canvasStandard?: { small?: number; medium?: number; large?: number };
      canvasGallery?: { small?: number; medium?: number; large?: number };
    };
    styleOptions?: Array<{ key: string; label: string }>;
    styleOptionsSecondary?: Array<{ key: string; label: string }>;
  };
}

const { service } = Astro.props;

const DEFAULT_ARTWORK_FEE = 5.0;
const artworkFee = service.artworkFee != null ? Number(service.artworkFee) : DEFAULT_ARTWORK_FEE;
const artworkBundledWithDigital = service.artworkBundledWithDigital !== false; // default true
const digitalPrice = Number(service.digitalPrice) || 0;
const digitalPriceSecondary = Number(service.digitalPriceSecondary) || 0;
const digitalPriceBoth = Number(service.digitalPriceBoth) || 0;
const animationMusicPrice = Number(service.animationMusicPrice) || 0;
const animationVoPrice = Number(service.animationVoPrice) || 0;
const styleCount = (service.styleOptions || []).length;
const styleCountSecondary = (service.styleOptionsSecondary || []).length;
const collectionLabel = service.collectionLabel || 'Collection 1';
const collectionLabelSecondary = service.collectionLabelSecondary || 'Collection 2';

const hasDigital = digitalPrice > 0;
const hasSecondaryCollection = styleCountSecondary > 0 && digitalPriceSecondary > 0;
const hasBothCollectionsPrice = digitalPriceBoth > 0 && hasSecondaryCollection;
const hasAnimationMusic = animationMusicPrice > 0;
const hasAnimationVo = animationVoPrice > 0;

function cheapestBasePrintPrice(upcharges: any): number | null {
  if (!upcharges) return null;
  const all: number[] = [];
  ['poster', 'canvasStandard', 'canvasGallery'].forEach((fmt) => {
    ['small', 'medium', 'large'].forEach((size) => {
      const p = Number(upcharges?.[fmt]?.[size]);
      if (p > 0) all.push(p);
    });
  });
  return all.length > 0 ? Math.min(...all) : null;
}

const cheapestPrintBase = cheapestBasePrintPrice(service.printUpcharges);
const hasPrint = cheapestPrintBase !== null;

const cheapestStandalonePrint = hasPrint ? (cheapestPrintBase as number) + artworkFee : null;
// Bundle starting price depends on whether artwork is bundled with digital:
//   - Cartoonify/Missing Moment (bundled): digital + base (artwork waived)
//   - YSYS (not bundled): digital + base + artwork (separate products)
const cheapestBundle = hasDigital && hasPrint
  ? (artworkBundledWithDigital
      ? digitalPrice + (cheapestPrintBase as number)
      : digitalPrice + (cheapestPrintBase as number) + artworkFee)
  : null;

// Render the strip if we have at least one base offer
const shouldRender = hasDigital || hasAnimationMusic || hasAnimationVo;

function priceLabel(p: number | null): string {
  if (p == null) return '—';
  return `£${p.toFixed(2)}`;
}
---

{shouldRender && (
  <section class="pricing-strip" aria-label="Pricing options">
    <h2 class="pricing-strip__title">Choose Your Order Type</h2>
    <div class="pricing-strip__cards">
      {hasDigital && (
        <div class="pricing-strip__card pricing-strip__card--cyan">
          <span class="pricing-strip__card-title">
            {hasSecondaryCollection
              ? `Digital — ${collectionLabel}`
              : `Digital ${styleCount > 0 ? 'Bundle' : 'Download'}`}
          </span>
          <span class="pricing-strip__card-price">{priceLabel(digitalPrice)}</span>
          <span class="pricing-strip__card-desc">
            {hasSecondaryCollection
              ? `All ${styleCount} ${collectionLabel.toLowerCase()} styles as digital files. No physical print.`
              : styleCount > 0
                ? `All ${styleCount} styles delivered as digital files. No physical print.`
                : 'Digital file delivered to your inbox. No physical print.'}
          </span>
        </div>
      )}

      {hasSecondaryCollection && (
        <div class="pricing-strip__card pricing-strip__card--violet">
          <span class="pricing-strip__card-title">Digital — {collectionLabelSecondary}</span>
          <span class="pricing-strip__card-price">{priceLabel(digitalPriceSecondary)}</span>
          <span class="pricing-strip__card-desc">
            All {styleCountSecondary} {collectionLabelSecondary.toLowerCase()} styles as digital files. No physical print.
          </span>
        </div>
      )}

      {hasBothCollectionsPrice && (
        <div class="pricing-strip__card pricing-strip__card--yellow">
          <span class="pricing-strip__card-badge">Best Digital</span>
          <span class="pricing-strip__card-title">Both Collections</span>
          <span class="pricing-strip__card-price">{priceLabel(digitalPriceBoth)}</span>
          <span class="pricing-strip__card-desc">
            All {styleCount + styleCountSecondary} styles across both collections — save £{(digitalPrice + digitalPriceSecondary - digitalPriceBoth).toFixed(2)}.
          </span>
        </div>
      )}

      {hasPrint && (
        <div class="pricing-strip__card pricing-strip__card--magenta">
          <span class="pricing-strip__card-title">Single Print</span>
          <span class="pricing-strip__card-price">from {priceLabel(cheapestStandalonePrint)}</span>
          <span class="pricing-strip__card-desc">
            {hasSecondaryCollection
              ? `One physical print of any style from either collection. Includes £${artworkFee.toFixed(2)} artwork fee.`
              : `One physical print + digital file. Includes £${artworkFee.toFixed(2)} artwork fee.`}
          </span>
        </div>
      )}

      {hasDigital && hasPrint && (
        <div class="pricing-strip__card pricing-strip__card--orange pricing-strip__card--best">
          <span class="pricing-strip__card-badge">Best Value</span>
          <span class="pricing-strip__card-title">Bundle + Prints</span>
          <span class="pricing-strip__card-price">from {priceLabel(cheapestBundle)}</span>
          <span class="pricing-strip__card-desc">
            {artworkBundledWithDigital
              ? `Digital${styleCount > 0 ? ' bundle' : ' file'} plus any number of prints. £${artworkFee.toFixed(2)} artwork fee waived per print.`
              : `Digital${styleCount > 0 ? ' bundle' : ' file'} plus any prints. Lyrics print artwork fee (£${artworkFee.toFixed(2)}) charged once per order.`}
          </span>
        </div>
      )}

      {hasAnimationMusic && (
        <div class="pricing-strip__card pricing-strip__card--yellow">
          <span class="pricing-strip__card-title">Animation (Music)</span>
          <span class="pricing-strip__card-price">{priceLabel(animationMusicPrice)}</span>
          <span class="pricing-strip__card-desc">
            30-second animated short with a custom soundtrack.
          </span>
        </div>
      )}

      {hasAnimationVo && (
        <div class="pricing-strip__card pricing-strip__card--violet">
          <span class="pricing-strip__card-title">Animation + Voiceover</span>
          <span class="pricing-strip__card-price">{priceLabel(animationVoPrice)}</span>
          <span class="pricing-strip__card-desc">
            30-second animated short with soundtrack AND AI voiceover.
          </span>
        </div>
      )}
    </div>
    <p class="pricing-strip__cta">
      Scroll down to <a href="#commission">start your commission</a> →
    </p>
  </section>
)}

<style>
  .pricing-strip {
    max-width: 1100px;
    margin: 0 auto 3rem;
    padding: 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
  }

  .pricing-strip__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    text-align: center;
    margin: 0 0 1.75rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--text, #fafafa);
  }

  .pricing-strip__cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .pricing-strip__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.75rem 1.25rem 1.5rem;
    background: rgba(0, 0, 0, 0.35);
    border: 2px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }

  .pricing-strip__card:hover {
    transform: translateY(-2px);
  }

  /* ── Per-card accent colours (drawn from the Pixel8 logo palette) ──── */

  .pricing-strip__card--cyan {
    border-color: #00BCD4;
  }
  .pricing-strip__card--cyan .pricing-strip__card-price {
    color: #00BCD4;
  }
  .pricing-strip__card--cyan:hover {
    box-shadow: 0 0 24px rgba(0, 188, 212, 0.25);
  }

  .pricing-strip__card--magenta {
    border-color: #E91E7B;
  }
  .pricing-strip__card--magenta .pricing-strip__card-price {
    color: #E91E7B;
  }
  .pricing-strip__card--magenta:hover {
    box-shadow: 0 0 24px rgba(233, 30, 123, 0.25);
  }

  .pricing-strip__card--orange {
    border-color: #F07828;
    background: linear-gradient(135deg, rgba(240, 120, 40, 0.10), rgba(0, 0, 0, 0.35));
  }
  .pricing-strip__card--orange .pricing-strip__card-price {
    color: #F07828;
  }
  .pricing-strip__card--orange:hover {
    box-shadow: 0 0 28px rgba(240, 120, 40, 0.32);
  }

  .pricing-strip__card--yellow {
    border-color: #FFEB3B;
  }
  .pricing-strip__card--yellow .pricing-strip__card-price {
    color: #FFEB3B;
  }
  .pricing-strip__card--yellow:hover {
    box-shadow: 0 0 24px rgba(255, 235, 59, 0.25);
  }

  .pricing-strip__card--violet {
    border-color: #7C4DFF;
  }
  .pricing-strip__card--violet .pricing-strip__card-price {
    color: #7C4DFF;
  }
  .pricing-strip__card--violet:hover {
    box-shadow: 0 0 24px rgba(124, 77, 255, 0.28);
  }

  /* "Best Value" Bundle card — same orange treatment but slightly brighter */
  .pricing-strip__card--best {
    border-color: #F07828;
  }

  .pricing-strip__card-badge {
    position: absolute;
    top: -10px;
    right: 12px;
    padding: 0.25rem 0.625rem;
    background: #F07828;
    color: #000;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 999px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .pricing-strip__card-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text, #fafafa);
  }

  .pricing-strip__card-price {
    font-family: 'Space Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    /* default fallback; per-card accent classes override */
    color: #F07828;
  }

  .pricing-strip__card-desc {
    font-size: 0.875rem;
    color: var(--text-muted, #a1a1aa);
    line-height: 1.5;
    margin-top: auto;
  }

  .pricing-strip__cta {
    margin: 1.5rem 0 0;
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-muted, #a1a1aa);
  }

  .pricing-strip__cta a {
    color: #F07828;
    text-decoration: none;
    font-weight: 600;
  }

  .pricing-strip__cta a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .pricing-strip {
      padding: 1.5rem 1rem;
    }

    .pricing-strip__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
