---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  {
    label: 'Services',
    href: '/your-way',
    children: [
      { label: 'Photo Restoration', href: '/your-way/photo-restoration' },
      { label: 'Stills to Reels', href: '/your-way/stills-to-reels' },
      { label: 'Bespoke Commission', href: '/your-way/bespoke' },
    ],
  },
  {
    label: 'Shop',
    href: '/store',
    children: [
      { label: 'All Collections', href: '/store' },
      { label: 'Neon Glow', href: '/store/neon-glow' },
      { label: 'Pop Art', href: '/store/pop-art' },
      { label: 'Retro Vibes', href: '/store/retro-vibes' },
      { label: 'Pixel Art', href: '/store/pixel-art' },
      { label: 'Minimalist Cool', href: '/store/minimalist-cool' },
      { label: 'Abstract Burst', href: '/store/abstract-burst' },
      { label: 'Noir', href: '/store/noir' },
      { label: 'Geometric', href: '/store/geometric' },
      { label: 'Street Art', href: '/store/street-art' },
      { label: 'Watercolour', href: '/store/watercolour' },
    ],
  },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-bg-primary/90 backdrop-blur-md border-b border-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 flex flex-col leading-none">
        <span class="flex items-baseline">
          <span class="font-montserrat font-extrabold text-2xl text-off-white tracking-tight">PIXEL</span>
          <span class="font-montserrat font-extrabold text-2xl logo-gradient">8</span>
        </span>
        <span class="font-montserrat text-[0.5rem] font-semibold tracking-[0.25em] text-deep-grey uppercase mt-0.5">Pop. Art. Motion.</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          link.children ? (
            <div class="relative group">
              <button class="nav-link flex items-center gap-1 px-3 py-2">
                {link.label}
                <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class={`absolute top-full left-0 mt-1 bg-bg-secondary border border-edge-line border-t-2 border-t-pop-orange opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 shadow-xl ${link.label === 'Shop' ? 'w-[400px] grid grid-cols-2' : 'w-52'}`}>
                {link.children.map((child, i) => (
                  <a href={child.href}
                     class={`block px-4 py-2.5 font-montserrat text-xs text-mid-grey hover:text-pop-orange hover:bg-bg-tertiary transition-colors uppercase tracking-wider font-semibold ${link.label === 'Shop' && i === 0 ? 'col-span-2 border-b border-edge-line' : ''}`}>
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={link.href} class="nav-link px-3 py-2">{link.label}</a>
          )
        ))}
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-3">
        <!-- Social Icons (desktop) -->
        <div class="hidden lg:flex items-center gap-2">
          <a href="https://facebook.com/pixel8multimedia" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-deep-grey hover:text-pop-orange transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://instagram.com/pixel8multimedia" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-deep-grey hover:text-pop-orange transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://x.com/pixel8multi" target="_blank" rel="noopener noreferrer" aria-label="X" class="text-deep-grey hover:text-pop-orange transition-colors">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.265 5.64 5.899-5.64zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://tiktok.com/@pixel8multimedia" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="text-deep-grey hover:text-pop-orange transition-colors">
            <svg class="w-3.5 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.02a8.16 8.16 0 004.77 1.52V7.1a4.85 4.85 0 01-1-.41z"/></svg>
          </a>
        </div>

        <!-- Cart -->
        <button id="cart-toggle" class="relative p-2 text-mid-grey hover:text-off-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span id="cart-count" class="absolute -top-0.5 -right-0.5 bg-hot-magenta text-white text-[0.6rem] font-mono font-bold rounded-full w-4 h-4 flex items-center justify-center hidden">0</span>
        </button>

        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-off-white hover:text-pop-orange transition-colors">
          <svg class="w-6 h-6" id="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-bg-primary border-t border-edge-line">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        link.children ? (
          <div>
            <div class="font-montserrat text-off-white uppercase tracking-wider py-2 text-sm font-bold text-pop-orange">
              {link.label}
            </div>
            {link.children.map((child) => (
              <a href={child.href}
                 class="block pl-4 py-2 font-dm text-sm text-mid-grey hover:text-pop-orange transition-colors">
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={link.href}
             class="block py-2 font-montserrat text-off-white uppercase tracking-wider text-sm hover:text-pop-orange transition-colors font-semibold">
            {link.label}
          </a>
        )
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  function updateNavState(scrolled: boolean) {
    if (scrolled) {
      navbar?.classList.add('bg-bg-primary', 'border-b-edge-line');
      navbar?.classList.remove('bg-bg-primary/90', 'border-transparent');
    } else {
      navbar?.classList.remove('bg-bg-primary', 'border-b-edge-line');
      navbar?.classList.add('bg-bg-primary/90', 'border-transparent');
    }
  }

  updateNavState(window.scrollY > 20);
  window.addEventListener('scroll', () => updateNavState(window.scrollY > 20));

  mobileMenuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden', !isHidden);
    closeIcon?.classList.toggle('hidden', isHidden);
  });

  import { cartCount, cartOpen } from '../stores/cart';

  const cartCountEl = document.getElementById('cart-count');
  const cartToggle = document.getElementById('cart-toggle');

  cartCount.subscribe((count) => {
    if (cartCountEl) {
      cartCountEl.textContent = String(count);
      count > 0 ? cartCountEl.classList.remove('hidden') : cartCountEl.classList.add('hidden');
    }
  });

  cartToggle?.addEventListener('click', () => {
    cartOpen.set(!cartOpen.get());
  });
</script>
