---
interface Testimonial {
  _id: string;
  customerName: string;
  location: string;
  rating: number;
  quote: string;
  product: string;
}

interface Props {
  testimonials?: Testimonial[];
}

// Accept Sanity data as props, fall back to empty array
const { testimonials = [] } = Astro.props;
---

<section class="py-16 bg-bg-primary overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-10">
    <div class="text-center reveal">
      <div class=" mb-4">Happy Customers</div>
      <h2 class="section-heading">WHAT OUR CUSTOMERS SAY</h2>
    </div>
  </div>

  <div class="relative">
    <div id="testimonial-track" class="flex gap-6 testimonial-scroll" style="width: max-content;">
      {[...testimonials, ...testimonials].map((t, i) => (
        <div class="w-80 flex-shrink-0 bg-bg-secondary border-4 border-edge-line p-6"
             style="">
          <div class="flex gap-1 mb-4">
            {Array(t.rating).fill(null).map(() => (
              <svg class="w-5 h-5 text-pop-orange" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="font-dm text-gray-300 text-sm leading-relaxed mb-5 italic">
            &ldquo;{t.quote}&rdquo;
          </blockquote>
          <div class="border-t-2 border-gray-700 pt-4">
            <p class="font-montserrat font-semibold text-off-white text-sm">{t.customerName}</p>
            <p class="font-dm text-gray-500 text-xs">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial-scroll {
    animation: scroll-left 30s linear infinite;
  }

  .testimonial-scroll:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
