---
---
<div class="text-center reveal">
  <h2 class="font-montserrat text-3xl md:text-4xl font-bold text-off-white mb-3">Join the Gallery</h2>
  <p class="font-dm text-mid-grey text-sm mb-6 max-w-md mx-auto">
    New drops, exclusive collections, and pop culture inspiration — straight to your inbox.
  </p>
  <form
    class="newsletter-form flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
    data-source="join-the-gallery"
    novalidate
  >
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="newsletter-input flex-1 bg-bg-primary border border-edge-line text-off-white font-dm text-sm px-4 py-3 focus:outline-none focus:border-pop-orange transition-colors rounded"
      aria-label="Email address"
    />
    <button type="submit" class="newsletter-submit btn-primary py-3 px-6 text-xs">Subscribe</button>
  </form>
  <p class="newsletter-feedback font-dm text-sm mt-4 hidden" role="status" aria-live="polite"></p>
  <p class="font-dm text-xs text-deep-grey mt-3">No spam, ever. Unsubscribe any time.</p>
</div>

<!--
  NOTE: This component does NOT include its own JS submit handler.
  The handler in Footer.astro auto-wires every .newsletter-form on the page.
  Footer.astro renders on every page so the handler is always loaded.
-->
