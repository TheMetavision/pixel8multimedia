---
import { urlFor } from '../lib/sanity';
import { PRICES, STYLE_LABELS, CATEGORY_LABELS } from '../data/products';
interface Props {
  product: {
    title: string;
    slug: string;
    category?: string;
    style?: string;
    accentColor?: string;
    prices?: any;
    images?: any[];
    serviceHeroUrl?: string; // passed through for personalised products
  };
}
const { product } = Astro.props;

// Personalised products link to the matching service page
const isPersonalised = product.category === 'personalised';
const serviceSlug = isPersonalised ? product.slug.replace(/^personalised-/, '') : null;
const href = isPersonalised ? `/services/${serviceSlug}` : `/store/${product.slug}`;

// Image: use product image if set, fallback to service hero for personalised items
const productImageUrl = product.images?.[0]?.asset
  ? urlFor(product.images[0]).width(600).height(800).url()
  : null;
const imageUrl = productImageUrl || product.serviceHeroUrl || null;

const lowestPrice = product.prices?.poster?.small || PRICES.poster.small;
const accent = product.accentColor || '#F07828';
const styleLabel = product.style ? (STYLE_LABELS[product.style] || product.style) : '';
const categoryLabel = product.category ? (CATEGORY_LABELS[product.category] || product.category) : '';

// CTA label differs for personalised
const ctaLabel = isPersonalised ? 'Commission' : 'Quick View';
---
<a href={href} class="product-card group block" data-category={product.category} data-style={product.style} data-title={product.title?.toLowerCase()}>
  <div class="aspect-[3/4] relative overflow-hidden">
    {imageUrl ? (
      <img src={imageUrl} alt={product.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
    ) : (
      <div class="img-placeholder w-full h-full">
        <span class="font-montserrat text-xs uppercase tracking-widest">{product.title}</span>
      </div>
    )}
    {styleLabel && !isPersonalised && (
      <span class="absolute top-2 left-2 bg-black/70 backdrop-blur-sm text-xs font-montserrat font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full border border-white/10" style={`color: ${accent}`}>
        {styleLabel}
      </span>
    )}
    {isPersonalised && (
      <span class="absolute top-2 left-2 bg-pixel-cyan/90 backdrop-blur-sm text-xs font-montserrat font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-black">
        Bespoke
      </span>
    )}
    <div class="absolute inset-0 bg-bg-primary/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center backdrop-blur-sm">
      <span class="font-montserrat text-xs font-bold uppercase tracking-widest text-off-white border border-off-white/50 px-4 py-2 rounded hover:bg-off-white hover:text-black transition-colors">{ctaLabel}</span>
    </div>
  </div>
  <div class="p-3 flex items-start justify-between gap-2">
    <div class="min-w-0">
      <h3 class="font-dm text-sm text-off-white font-medium truncate">{product.title}</h3>
      {categoryLabel && (
        <span class="font-montserrat text-[0.65rem] text-deep-grey uppercase tracking-wider">{categoryLabel}</span>
      )}
    </div>
    <span class="price-tag text-sm flex-shrink-0">From £{lowestPrice.toFixed(2)}</span>
  </div>
</a>
<style define:vars={{ accent }}>
  .product-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 30px color-mix(in srgb, var(--accent) 20%, transparent);
  }
</style>
