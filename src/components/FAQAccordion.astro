---
interface FAQ {
  _id: string;
  question: string;
  answer: string;
  sortOrder: number;
}

interface Props {
  faqs?: FAQ[];
}

const { faqs = [] } = Astro.props;
---

<div class="space-y-3" id="faq-accordion">
  {faqs.map((faq, i) => (
    <div class="border-4 border-edge-line bg-bg-secondary faq-item" style="">
      <button
        class="w-full flex items-center justify-between p-5 text-left faq-trigger"
        aria-expanded="false"
        data-index={i}>
        <span class="font-montserrat font-semibold text-off-white text-sm md:text-base pr-4 leading-snug">
          {faq.question}
        </span>
        <svg class="w-5 h-5 text-pop-orange flex-shrink-0 faq-icon transition-transform duration-300"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div class="faq-answer overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
        <div class="px-5 pb-5 border-t-2 border-gray-700">
          <p class="font-dm text-gray-300 text-sm leading-relaxed pt-4">
            {faq.answer}
          </p>
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  const triggers = document.querySelectorAll('.faq-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      const answer = trigger.nextElementSibling as HTMLElement;
      const icon = trigger.querySelector('.faq-icon') as HTMLElement;

      triggers.forEach((t) => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          const a = t.nextElementSibling as HTMLElement;
          const ic = t.querySelector('.faq-icon') as HTMLElement;
          if (a) a.style.maxHeight = '0';
          if (ic) ic.style.transform = 'rotate(0deg)';
        }
      });

      if (isExpanded) {
        trigger.setAttribute('aria-expanded', 'false');
        if (answer) answer.style.maxHeight = '0';
        if (icon) icon.style.transform = 'rotate(0deg)';
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        if (answer) answer.style.maxHeight = answer.scrollHeight + 'px';
        if (icon) icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
