---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { allBlogPostsQuery } from '../../lib/queries';

const blogPosts = await sanityClient.fetch(allBlogPostsQuery);
---

<BaseLayout
  title="Blog — Wall Art Tips & Inspiration"
  description="Pixel8 Multimedia blog: wall art inspiration, how-to guides, gift ideas, and behind-the-scenes content from the UK's boldest pop culture art brand."
>
  <section class="relative bg-bg-secondary  py-16 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-pop-orange"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 50%, rgba(236,0,140,0.1) 0%, transparent 50%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <nav class="flex items-center gap-2 font-dm text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-pop-orange transition-colors">Home</a>
        <span>/</span>
        <span class="text-off-white">Blog</span>
      </nav>
      <div class=" inline-block mb-4">Ideas & Inspiration</div>
      <h1 class="font-montserrat font-bold text-5xl md:text-7xl text-off-white tracking-wide mb-4"
          style="text-shadow: 4px 4px 0 rgba(0,0,0,0.5);">
        THE <span class="text-pop-orange">BLOG</span>
      </h1>
      <p class="font-dm text-gray-300 text-lg">Wall art tips, gift ideas, and pop culture inspiration.</p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {blogPosts.map((post: any) => {
        const postImgUrl = post.mainImage?.asset ? urlFor(post.mainImage).width(700).height(394).url() : null;
        return (
        <article class="bg-bg-secondary border-4 border-edge-line overflow-hidden group transition-all duration-300 hover:-translate-y-1"
                 style="">
          <div class="aspect-video relative overflow-hidden">
            {postImgUrl ? (
              <img src={postImgUrl} alt={post.mainImage?.alt || post.title} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="w-full h-full img-placeholder flex items-center justify-center">
                <span class="text-gray-500 font-montserrat font-semibold tracking-widest text-xs uppercase">BLOG IMAGE</span>
              </div>
            )}
            <div class="absolute top-3 left-3">
              <span class="bg-pop-orange text-white font-dm font-bold text-xs px-2 py-1 border-2 border-edge-line">
                {post.category}
              </span>
            </div>
          </div>
          <div class="p-6">
            <p class="font-dm text-gray-500 text-xs uppercase tracking-widest mb-2">
              {new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
            <h2 class="font-montserrat font-semibold text-off-white text-xl leading-snug mb-3 group-hover:text-pop-orange transition-colors">
              {post.title}
            </h2>
            <p class="font-dm text-gray-400 text-sm leading-relaxed mb-5">{post.excerpt}</p>
            <a href={`/blog/${post.slug}`}
               class="inline-flex items-center gap-2 font-montserrat font-semibold text-sm text-pixel-cyan hover:text-pop-orange transition-colors uppercase tracking-wide">
              Read More
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>
        );
      })}
    </div>
  </div>
</BaseLayout>
