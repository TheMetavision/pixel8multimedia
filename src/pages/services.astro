---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Your Way — Custom Services"
  description="Commission bespoke artwork, restore treasured photos, or transform images into animations. Pixel8 Multimedia custom services."
>
  <!-- Hero -->
  <section class="bg-bg-secondary py-20 border-b border-edge-line">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <span class="font-mono text-xs text-pixel-cyan uppercase tracking-widest">Custom Services</span>
      <h1 class="section-heading mt-2 mb-4">Your Way</h1>
      <p class="font-dm text-mid-grey text-lg">Your vision, our craft. From photo restoration to custom commissions — every piece is uniquely yours.</p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-bg-primary">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">

      <!-- Photo Restoration -->
      <div class="grid lg:grid-cols-2 gap-12 items-center reveal">
        <div class="aspect-[4/3] bg-bg-secondary rounded-lg border border-edge-line flex items-center justify-center order-2 lg:order-1">
          <span class="font-montserrat text-sm text-deep-grey uppercase tracking-widest">Before / After Preview</span>
        </div>
        <div class="order-1 lg:order-2">
          <div class="w-12 h-12 bg-pop-orange/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-pop-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h2 class="font-montserrat text-3xl font-bold text-off-white mb-4">Photo Restoration</h2>
          <p class="font-dm text-mid-grey leading-relaxed mb-4">Breathe new life into treasured memories. We combine AI-enhanced technology with human artistry to restore, repair, and revitalise old or damaged photographs.</p>
          <p class="font-mono text-lg text-pop-orange mb-6">From £25</p>
          <a href="/your-way/photo-restoration" class="btn-primary">Start Restoration →</a>
        </div>
      </div>

      <!-- Stills to Reels -->
      <div class="grid lg:grid-cols-2 gap-12 items-center reveal">
        <div>
          <div class="w-12 h-12 bg-pixel-cyan/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-pixel-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </div>
          <h2 class="font-montserrat text-3xl font-bold text-off-white mb-4">Stills to Reels</h2>
          <p class="font-dm text-mid-grey leading-relaxed mb-4">Our signature service. Transform your favourite static images into dynamic, cinematic animations. Perfect for social media content, digital art displays, or a truly unique gift.</p>
          <p class="font-mono text-lg text-pixel-cyan mb-6">From £35</p>
          <a href="/your-way/stills-to-reels" class="btn-cyan">Animate Your Image →</a>
        </div>
        <div class="aspect-[4/3] bg-bg-secondary rounded-lg border border-edge-line flex items-center justify-center">
          <span class="font-montserrat text-sm text-deep-grey uppercase tracking-widest">Animation Preview</span>
        </div>
      </div>

      <!-- Bespoke Commission -->
      <div class="grid lg:grid-cols-2 gap-12 items-center reveal">
        <div class="aspect-[4/3] bg-bg-secondary rounded-lg border border-edge-line flex items-center justify-center order-2 lg:order-1">
          <span class="font-montserrat text-sm text-deep-grey uppercase tracking-widest">Style Gallery</span>
        </div>
        <div class="order-1 lg:order-2">
          <div class="w-12 h-12 bg-hot-magenta/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-hot-magenta" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h2 class="font-montserrat text-3xl font-bold text-off-white mb-4">Bespoke Commission</h2>
          <p class="font-dm text-mid-grey leading-relaxed mb-4">Want something completely unique? Tell us your vision — a person, a pet, a scene, a style — and we'll create a one-of-a-kind piece of pop culture art tailored to you.</p>
          <p class="font-mono text-lg text-hot-magenta mb-6">From £45</p>
          <a href="/your-way/bespoke" class="btn-magenta">Brief Us →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-bg-secondary">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-heading mb-12 reveal">How It Works</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 reveal">
        {[
          { step: '01', title: 'Brief', desc: 'Tell us what you want — upload images and share your vision.' },
          { step: '02', title: 'Create', desc: 'Our artists get to work crafting your piece.' },
          { step: '03', title: 'Review', desc: 'We share a digital proof for your approval.' },
          { step: '04', title: 'Deliver', desc: 'Approved artwork is printed and shipped to you.' },
        ].map((item) => (
          <div class="text-center">
            <span class="font-mono text-3xl text-pop-orange font-bold">{item.step}</span>
            <h3 class="font-montserrat text-lg font-bold text-off-white mt-2 mb-1">{item.title}</h3>
            <p class="font-dm text-sm text-mid-grey">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
