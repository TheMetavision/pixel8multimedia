---
// src/pages/services/index.astro
// Services listing page — fetches all services from Sanity, renders grid
export const prerender = false;

import { sanityClient } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = await sanityClient.fetch(`
  *[_type == "service"] | order(sortOrder asc) {
    _id,
    title,
    description,
    slug,
    "heroImage": heroImage.asset->url
  }
`);
---

<BaseLayout
  title="Services — Pixel8 Multimedia"
  description="Bespoke photo transformations, AI art commissions, and creative services from Pixel8 Multimedia."
>
  <div class="services-index">
    <header class="services-index__header">
      <span class="services-index__eyebrow">Your Way</span>
      <h1 class="services-index__title">Our Services</h1>
      <p class="services-index__subtitle">
        Every creation is bespoke. Choose a service, upload your photos, and let us bring your vision to life.
      </p>
    </header>

    <div class="services-index__grid">
      {services.map((svc) => (
        <a href={`/services/${svc.slug.current}`} class="service-card">
          {svc.heroImage ? (
            <img
              src={svc.heroImage}
              alt={svc.title}
              class="service-card__image"
              loading="lazy"
            />
          ) : (
            <div class="service-card__placeholder">
              <span>✨</span>
            </div>
          )}
          <div class="service-card__body">
            <h2 class="service-card__title">{svc.title}</h2>
            <p class="service-card__desc">{svc.description}</p>
            <span class="service-card__cta">Start Commission →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .services-index {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  .services-index__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .services-index__eyebrow {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    color: #00BCD4;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 0.75rem;
  }

  .services-index__title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    color: #F0EDE6;
    text-transform: uppercase;
  }

  .services-index__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #8A8A8E;
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .services-index__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* ── Service Card ──────── */
  .service-card {
    display: flex;
    flex-direction: column;
    background: #141418;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: #F07828;
    box-shadow: 0 8px 24px rgba(240, 120, 40, 0.15);
  }

  .service-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .service-card__placeholder {
    width: 100%;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #F07828 0%, #E91E7B 100%);
    font-size: 3rem;
  }

  .service-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .service-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
    color: #F0EDE6;
    text-transform: uppercase;
  }

  .service-card__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #8A8A8E;
    line-height: 1.55;
    margin: 0 0 1rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-card__cta {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: #F07828;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
