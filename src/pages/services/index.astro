---
// src/pages/services/index.astro
// Services listing page — fetches all services from Sanity, renders grid
export const prerender = false;

import { sanityClient } from '../../lib/sanity';
import Layout from '../../layouts/Layout.astro';

const services = await sanityClient.fetch(`
  *[_type == "service"] | order(sortOrder asc) {
    _id,
    title,
    description,
    slug,
    "heroImage": heroImage.asset->url
  }
`);
---

<Layout
  title="Services — Pixel8 Multimedia"
  description="Bespoke photo transformations, AI art commissions, and creative services from Pixel8 Multimedia."
>
  <main class="services-index">
    <header class="services-index__header">
      <h1 class="services-index__title">Our Services</h1>
      <p class="services-index__subtitle">
        Every creation is bespoke. Choose a service, upload your photos, and let us bring your vision to life.
      </p>
    </header>

    <div class="services-index__grid">
      {services.map((svc) => (
        <a href={`/services/${svc.slug.current}`} class="service-card">
          {svc.heroImage ? (
            <img
              src={svc.heroImage}
              alt={svc.title}
              class="service-card__image"
              loading="lazy"
            />
          ) : (
            <div class="service-card__placeholder">
              <span>✨</span>
            </div>
          )}
          <div class="service-card__body">
            <h2 class="service-card__title">{svc.title}</h2>
            <p class="service-card__desc">{svc.description}</p>
            <span class="service-card__cta">
              Start Commission →
            </span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .services-index {
    max-width: 1120px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .services-index__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .services-index__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  .services-index__subtitle {
    font-size: 1.125rem;
    color: var(--text-muted, #6b7280);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .services-index__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* ── Service Card ──────── */
  .service-card {
    display: flex;
    flex-direction: column;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #e2e5ea);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .service-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .service-card__placeholder {
    width: 100%;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
    font-size: 3rem;
  }

  .service-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .service-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .service-card__desc {
    font-size: 0.875rem;
    color: var(--text-muted, #6b7280);
    line-height: 1.55;
    margin: 0 0 1rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-card__cta {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent, #7c3aed);
    letter-spacing: 0.01em;
  }

  @media (prefers-color-scheme: dark) {
    .service-card {
      background: #1e1e24;
      border-color: #2e2e38;
    }
    .service-card:hover {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    }
  }
</style>
