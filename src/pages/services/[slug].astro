---
// src/pages/services/[slug].astro
// Dynamic service page — fetches from Sanity, renders hero, gallery, steps, commission form
export const prerender = false;

import { sanityClient } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CommissionForm from '../../components/CommissionForm.jsx';
import '../../styles/commission-form.css';

const { slug } = Astro.params;

const service = await sanityClient.fetch(
  `*[_type == "service" && slug.current == $slug][0]{
    _id,
    title,
    description,
    extendedDescription,
    importantNote,
    slug,
    steps,
    price,
    hasFileUpload,
    hasDigitalDelivery,
    hasPrintOrder,
    "heroImage": heroImage.asset->url,
    examples[]{
      label,
      images[]{
        tag,
        "url": image.asset->url
      },
      videos[]{
        youtubeId,
        tag,
        title
      },
      audioTracks[]{
        title,
        duration,
        "coverUrl": coverImage.asset->url,
        "audioUrl": audioFile.asset->url
      }
    }
  }`,
  { slug }
);

if (!service) {
  return Astro.redirect('/404');
}

const seoTitle = `${service.title} | Pixel8 Multimedia`;
const seoDesc = service.description?.substring(0, 155);

const extParagraphs = service.extendedDescription
  ? service.extendedDescription.split(/\n\n+/).filter(Boolean)
  : [];
---

<BaseLayout title={seoTitle} description={seoDesc}>
  <div class="service-page">
    <!-- Hero Section -->
    <section class="service-page__hero">
      {service.heroImage && (
        <div class="service-page__hero-frame">
          <img
            src={service.heroImage}
            alt={service.title}
            class="service-page__hero-image"
            loading="eager"
          />
        </div>
      )}
      <div class="service-page__hero-content">
        <h1 class="service-page__title">{service.title}</h1>
        <p class="service-page__description">{service.description}</p>
      </div>
    </section>

    {extParagraphs.length > 0 && (
      <section class="service-page__extended">
        {extParagraphs.map((para) => (
          <p>{para}</p>
        ))}
      </section>
    )}

    <!-- Gallery Examples -->
    {service.examples?.length > 0 && (
      <section class="service-page__gallery">
        <h2 class="service-page__section-title">Examples</h2>
        {service.examples.map((example) => (
          <div class="example-block">
            {example.label && (
              <h3 class="example-block__label">{example.label}</h3>
            )}

            {example.images?.length > 0 && (
              <div class="example-block__images">
                {example.images.filter(img => img.url).map((img) => (
                  <figure class="example-block__figure">
                    <img
                      src={img.url}
                      alt={`${example.label || service.title} — ${img.tag || ''}`}
                      loading="lazy"
                      class="example-block__image"
                    />
                    {img.tag && (
                      <figcaption class="example-block__tag">{img.tag}</figcaption>
                    )}
                  </figure>
                ))}
              </div>
            )}

            {example.videos?.length > 0 && (
              <div class="example-block__videos">
                {example.videos.map((vid) => (
                  <div class="example-block__video-wrap">
                    <div class="example-block__video-container">
                      <iframe
                        src={`https://www.youtube.com/embed/${vid.youtubeId}`}
                        title={vid.title || `${example.label} video`}
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    </div>
                    {vid.tag && (
                      <p class="example-block__video-tag">{vid.tag}</p>
                    )}
                  </div>
                ))}
              </div>
            )}

            {example.audioTracks?.length > 0 && (
              <div class="example-block__audio-list">
                {example.audioTracks.map((track) => (
                  <div class="example-block__audio-item">
                    {track.coverUrl && (
                      <img
                        src={track.coverUrl}
                        alt={track.title}
                        class="example-block__audio-cover"
                        loading="lazy"
                      />
                    )}
                    <div class="example-block__audio-info">
                      <p class="example-block__audio-title">{track.title}</p>
                      {track.duration && (
                        <span class="example-block__audio-duration">{track.duration}</span>
                      )}
                    </div>
                    {track.audioUrl && (
                      <audio controls preload="none" class="example-block__audio-player">
                        <source src={track.audioUrl} />
                      </audio>
                    )}
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </section>
    )}

    <!-- How It Works -->
    {service.steps?.length > 0 && (
      <section class="service-page__how-it-works">
        <h2 class="service-page__section-title">How It Works</h2>
        <ol class="service-page__steps">
          {service.steps.map((step, i) => (
            <li class="service-page__step">
              <span class="service-page__step-number">{i + 1}</span>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>
      </section>
    )}

    {service.importantNote && (
      <aside class="service-page__note">
        <strong>Please Note:</strong> {service.importantNote}
      </aside>
    )}

    <!-- Commission Form -->
    <section class="service-page__commission" id="commission">
      <CommissionForm
        client:visible
        service={{
          slug: service.slug.current,
          title: service.title,
          hasFileUpload: service.hasFileUpload,
          hasDigitalDelivery: service.hasDigitalDelivery,
          hasPrintOrder: service.hasPrintOrder,
        }}
      />
    </section>
  </div>
</BaseLayout>

<style>
  /* ── Page container ─────────────────────── */
  .service-page {
    max-width: 1060px;
    margin: 0 auto;
    padding: 1rem 1.5rem 4rem;
  }

  /* ── Hero ────────────────────────────────── */
  .service-page__hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .service-page__hero-frame {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2rem;
    background: transparent;
  }

  .service-page__hero-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .service-page__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  .service-page__description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-muted, #a1a1aa);
    max-width: 640px;
    margin: 0 auto;
  }

  .service-page__extended {
    max-width: 700px;
    margin: 0 auto 2.5rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted, #a1a1aa);
    text-align: center;
  }

  .service-page__extended p {
    margin: 0 0 1rem;
  }

  .service-page__extended p:last-child {
    margin-bottom: 0;
  }

  /* ── Section titles ─────────────────────── */
  .service-page__section-title {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 2rem;
    letter-spacing: -0.02em;
  }

  /* ── Gallery Examples ───────────────────── */
  .service-page__gallery {
    margin-bottom: 3rem;
  }

  .example-block {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border, #27272a);
  }

  .example-block:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .example-block__label {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 1.25rem;
    text-align: center;
    color: var(--text, #fafafa);
  }

  /* Images grid — centre each image within its cell */
  .example-block__images {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    align-items: center;
  }

  .example-block__figure {
    margin: 0;
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background: transparent;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .example-block__image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    transition: transform 300ms ease;
  }

  .example-block__figure:hover .example-block__image {
    transform: scale(1.03);
  }

  .example-block__tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.25rem 0.625rem;
    background: rgba(0, 0, 0, 0.75);
    color: #F07828;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 6px;
    backdrop-filter: blur(8px);
    letter-spacing: 0.02em;
    z-index: 1;
  }

  /* Videos grid */
  .example-block__videos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .example-block__video-wrap {
    text-align: center;
  }

  .example-block__video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
    border: 1px solid var(--border, #27272a);
  }

  .example-block__video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .example-block__video-tag {
    margin: 0.625rem 0 0;
    font-size: 0.8125rem;
    color: var(--text-muted, #a1a1aa);
    font-weight: 500;
  }

  /* Audio tracks */
  .example-block__audio-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .example-block__audio-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--surface, #18181b);
    border: 1px solid var(--border, #27272a);
    border-radius: 10px;
  }

  .example-block__audio-cover {
    width: 48px;
    height: 48px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .example-block__audio-info {
    flex-shrink: 0;
    min-width: 120px;
  }

  .example-block__audio-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text, #fafafa);
  }

  .example-block__audio-duration {
    font-size: 0.75rem;
    color: var(--text-muted, #a1a1aa);
  }

  .example-block__audio-player {
    flex: 1;
    min-width: 0;
    height: 36px;
  }

  /* ── How It Works ───────────────────────── */
  .service-page__how-it-works {
    margin-bottom: 2.5rem;
  }

  .service-page__steps {
    list-style: none;
    padding: 0;
    max-width: 560px;
    margin: 0 auto;
  }

  .service-page__step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .service-page__step-number {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: #F07828;
    color: #000;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 50%;
  }

  .service-page__step p {
    margin: 0.25rem 0 0;
    line-height: 1.5;
    color: var(--text-muted, #a1a1aa);
  }

  /* ── Important Note ─────────────────────── */
  .service-page__note {
    max-width: 560px;
    margin: 0 auto 2rem;
    padding: 1rem 1.25rem;
    background: rgba(245, 158, 11, 0.08);
    border-left: 3px solid #f59e0b;
    border-radius: 6px;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--text-muted, #a1a1aa);
  }

  .service-page__note strong {
    color: #f59e0b;
  }

  /* ── Responsive ─────────────────────────── */
  @media (max-width: 640px) {
    .service-page {
      padding: 1rem 1rem 3rem;
    }

    .example-block__images {
      grid-template-columns: 1fr;
    }

    .example-block__videos {
      grid-template-columns: 1fr;
    }

    .example-block__audio-item {
      flex-wrap: wrap;
    }

    .example-block__audio-player {
      width: 100%;
    }
  }
</style>
