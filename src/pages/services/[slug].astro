---
// src/pages/services/[slug].astro
// Dynamic service page — fetches from Sanity, renders hero, gallery, steps,
// and the commission wizard (Phase 2 — replaces legacy single-form CommissionForm).
export const prerender = false;

import { sanityClient } from '../../lib/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CommissionWorkflow from '../../components/CommissionWorkflow.jsx';
import PricingStrip from '../../components/PricingStrip.astro';
import PrintPricingTable from '../../components/PrintPricingTable.astro';
import '../../styles/commission-workflow.css';

const { slug } = Astro.params;

const service = await sanityClient.fetch(
  `*[_type == "service" && slug.current == $slug][0]{
    _id,
    title,
    description,
    extendedDescription,
    importantNote,
    slug,
    steps,
    price,
    digitalPrice,
    digitalPriceSecondary,
    digitalPriceBoth,
    collectionLabel,
    collectionLabelSecondary,
    animationMusicPrice,
    animationVoPrice,
    artworkFee,
    artworkBundledWithDigital,
    artworkFeePerOrder,
    printSizeLabels,
    printUpcharges,
    styleOptions[]{ key, label, helperText },
    styleOptionsSecondary[]{ key, label, helperText },
    commissionEnabled,
    briefingFields,
    hasFileUpload,
    hasDigitalDelivery,
    hasPrintOrder,
    "heroImage": heroImage.asset->url,
    examples[]{
      label,
      images[]{
        tag,
        "url": image.asset->url
      },
      videos[]{
        youtubeId,
        tag,
        title
      },
      audioTracks[]{
        title,
        duration,
        "coverUrl": coverImage.asset->url,
        "audioUrl": audioFile.asset->url
      }
    }
  }`,
  { slug }
);

if (!service) {
  return Astro.redirect('/404');
}

// ── FAQs linked to this service ────────────────────────────────────────
// Returns service-specific FAQs in displayOrder. The two general
// "Custom Services" FAQs (no `service` ref set) appear only on /faqs.
const serviceFaqs = await sanityClient.fetch(
  `*[_type == "faq" && service._ref == $serviceId] | order(displayOrder asc) {
    _id, question, answer, displayOrder
  }`,
  { serviceId: service._id }
);

function slugifyQuestion(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '')
    .substring(0, 80);
}

const seoTitle = `${service.title} | Pixel8 Multimedia`;
const seoDesc = service.description?.substring(0, 155);

const extParagraphs = service.extendedDescription
  ? service.extendedDescription.split(/\n\n+/).filter(Boolean)
  : [];

// Helper: categorise example images.
//
// Three modes:
//
//   - 'collage' — example contains a "Collage"-tagged image. Triggers the SOYL
//     pattern: source-photos grid above + collage hero below.
//
//   - 'collections' — service has two style collections (primary + secondary)
//     AND the example images include tags from both. Renders the Original
//     hero, then two labelled sub-grids (one per collection). Used for Back
//     In Time's Modern Decades + Historical Periods.
//
//   - 'uniform' — all images share the same tag (typically "Original"). Renders
//     as a flat grid with no hero split. Used when an example is a set of
//     similar reference photos rather than a before/after transformation.
//
//   - 'standard' — the existing photoreal-service pattern: first image tagged
//     "Original" is the centred hero, remaining (differently-tagged) images
//     form the grid below.
//
// NOTE: collage trigger word is strictly "collage" — NOT "digital still",
// because that tag is widely used across photoreal services (Missing Moment,
// Crayon, Prankz, Scene Stealer, etc.) for the transformed output image.
function categoriseImages(images = [], primaryKeys = [], secondaryKeys = []) {
  const valid = images.filter((img) => img.url);
  if (!valid.length) return { mode: 'standard', original: null, rest: [] };

  // SOYL detection: any image tagged with a value containing "collage"
  const collage = valid.find((img) => {
    const t = (img.tag || '').toLowerCase();
    return t.includes('collage');
  });

  if (collage) {
    const sourcePhotos = valid.filter((img) => img !== collage);
    return { mode: 'collage', sourcePhotos, collage };
  }

  // Two-collection detection: service exposes a styleOptionsSecondary[] array
  // AND at least one example image is tagged with a secondary-collection key.
  // Buckets into Original (hero), primary collection (grid 1), secondary
  // collection (grid 2). Tag matching is case-insensitive against the keys.
  const hasTwoCollections = secondaryKeys.length > 0;
  if (hasTwoCollections) {
    const primaryKeysLower = primaryKeys.map((k) => String(k).toLowerCase());
    const secondaryKeysLower = secondaryKeys.map((k) => String(k).toLowerCase());

    const hasAnySecondary = valid.some((img) => {
      const t = (img.tag || '').toLowerCase();
      return secondaryKeysLower.includes(t);
    });

    if (hasAnySecondary) {
      const original = valid.find(
        (img) => img.tag && img.tag.toLowerCase().includes('original')
      ) || null;
      const primary = valid.filter((img) => {
        const t = (img.tag || '').toLowerCase();
        return primaryKeysLower.includes(t);
      });
      const secondary = valid.filter((img) => {
        const t = (img.tag || '').toLowerCase();
        return secondaryKeysLower.includes(t);
      });
      // Anything left over that didn't match Original / primary / secondary —
      // dropped into a fallback grid so nothing disappears silently
      const other = valid.filter(
        (img) =>
          img !== original &&
          !primary.includes(img) &&
          !secondary.includes(img)
      );
      return { mode: 'collections', original, primary, secondary, other };
    }
  }

  // Uniform-tag detection: every image has the SAME (non-empty) tag — render
  // as a flat grid. Handles the SOYL-pre-collage state where source photos are
  // tagged "Original" without a corresponding collage.
  const firstTag = valid[0].tag;
  const allSameTag = !!firstTag && valid.every((img) => img.tag === firstTag);
  if (allSameTag && valid.length > 1) {
    return { mode: 'uniform', images: valid };
  }

  // Standard photoreal service flow — first image tagged "Original" is the hero
  const first = valid[0];
  const isOriginal = first.tag && first.tag.toLowerCase().includes('original');
  if (isOriginal && valid.length > 1) {
    return { mode: 'standard', original: first, rest: valid.slice(1) };
  }
  return { mode: 'standard', original: null, rest: valid };
}

// Should the commission wizard be shown?
//  - Must be enabled in Sanity (commissionEnabled !== false)
//  - Must have at least one briefing field configured
const showCommissionWorkflow =
  service.commissionEnabled !== false &&
  Array.isArray(service.briefingFields) &&
  service.briefingFields.length > 0;

// Shape the service object passed to the React island — only fields the
// component actually needs, to keep the serialised props tight.
const serviceForWizard = {
  slug: service.slug.current,
  title: service.title,
  price: service.price,
  digitalPrice: service.digitalPrice,
  digitalPriceSecondary: service.digitalPriceSecondary,
  digitalPriceBoth: service.digitalPriceBoth,
  collectionLabel: service.collectionLabel,
  collectionLabelSecondary: service.collectionLabelSecondary,
  animationMusicPrice: service.animationMusicPrice,
  animationVoPrice: service.animationVoPrice,
  artworkFee: service.artworkFee,
  artworkBundledWithDigital: service.artworkBundledWithDigital,
  artworkFeePerOrder: service.artworkFeePerOrder,
  printSizeLabels: service.printSizeLabels,
  styleOptions: service.styleOptions,
  styleOptionsSecondary: service.styleOptionsSecondary,
  printUpcharges: service.printUpcharges,
  briefingFields: service.briefingFields,
};
---

<BaseLayout title={seoTitle} description={seoDesc}>
  <div class="service-page">
    <!-- Hero Section -->
    <section class="service-page__hero">
      {service.heroImage && (
        <div class="service-page__hero-frame">
          <img
            src={service.heroImage}
            alt={service.title}
            class="service-page__hero-image"
            loading="eager"
          />
        </div>
      )}
      <div class="service-page__hero-content">
        <h1 class="service-page__title">{service.title}</h1>
        <p class="service-page__description">{service.description}</p>
        {/*
          Legacy "From £X.XX" hero price removed in favour of the PricingStrip
          component below — which shows all three pricing paths clearly.
          For services not yet migrated (no digitalPrice), the strip won't
          render and we may want to add a hero price fallback here later.
        */}
        {service.price && !service.digitalPrice && (
          <p class="service-page__price">
            From <strong>£{service.price.toFixed(2)}</strong>
          </p>
        )}
      </div>
    </section>

    {extParagraphs.length > 0 && (
      <section class="service-page__extended">
        {extParagraphs.map((para) => (
          <p>{para}</p>
        ))}
      </section>
    )}

    <!-- Gallery Examples -->
    {service.examples?.length > 0 && (
      <section class="service-page__gallery">
        <h2 class="service-page__section-title">Examples</h2>
        {service.examples.map((example) => {
          const categorised = categoriseImages(
            example.images || [],
            (service.styleOptions || []).map((s) => s.key),
            (service.styleOptionsSecondary || []).map((s) => s.key)
          );
          return (
            <div class="example-block">
              {example.label && (
                <h3 class="example-block__label">{example.label}</h3>
              )}

              {/* ─── COLLAGE MODE — SOYL pattern: source photos → digital still ─── */}
              {categorised.mode === 'collage' && (
                <>
                  {categorised.sourcePhotos.length > 0 && (
                    <>
                      <h4 class="example-block__section-title">Source Moments</h4>
                      <div class="example-block__source-grid">
                        {categorised.sourcePhotos.map((img) => (
                          <figure class="example-block__source-figure">
                            <img
                              src={img.url}
                              alt={`${example.label || service.title} — source photo`}
                              loading="lazy"
                              class="example-block__source-image"
                            />
                          </figure>
                        ))}
                      </div>
                    </>
                  )}

                  <h4 class="example-block__section-title">
                    Digital Still
                    {service.digitalPrice && (
                      <span class="example-block__price-tag"> — £{service.digitalPrice.toFixed(2)}</span>
                    )}
                  </h4>
                  <div class="example-block__original">
                    <figure class="example-block__figure">
                      <img
                        src={categorised.collage.url}
                        alt={`${example.label || service.title} — Digital Still`}
                        loading="lazy"
                        class="example-block__image"
                      />
                      {categorised.collage.tag && (
                        <figcaption class="example-block__tag">{categorised.collage.tag}</figcaption>
                      )}
                    </figure>
                  </div>
                </>
              )}

              {/* ─── COLLECTIONS MODE — two-collection services (Back In Time) ─── */}
              {categorised.mode === 'collections' && (
                <>
                  {categorised.original && (
                    <div class="example-block__original">
                      <figure class="example-block__figure">
                        <img
                          src={categorised.original.url}
                          alt={`${example.label || service.title} — ${categorised.original.tag || ''}`}
                          loading="lazy"
                          class="example-block__image"
                        />
                        {categorised.original.tag && (
                          <figcaption class="example-block__tag">{categorised.original.tag}</figcaption>
                        )}
                      </figure>
                    </div>
                  )}

                  {categorised.primary.length > 0 && service.collectionLabel && (
                    <h4 class="example-block__collection-heading">
                      {service.collectionLabel}
                    </h4>
                  )}
                  {categorised.primary.length > 0 && (
                    <div class="example-block__images">
                      {categorised.primary.map((img) => (
                        <figure class="example-block__figure">
                          <img
                            src={img.url}
                            alt={`${example.label || service.title} — ${img.tag || ''}`}
                            loading="lazy"
                            class="example-block__image"
                          />
                          {img.tag && (
                            <figcaption class="example-block__tag">{img.tag}</figcaption>
                          )}
                        </figure>
                      ))}
                    </div>
                  )}

                  {categorised.secondary.length > 0 && service.collectionLabelSecondary && (
                    <h4 class="example-block__collection-heading">
                      {service.collectionLabelSecondary}
                    </h4>
                  )}
                  {categorised.secondary.length > 0 && (
                    <div class="example-block__images">
                      {categorised.secondary.map((img) => (
                        <figure class="example-block__figure">
                          <img
                            src={img.url}
                            alt={`${example.label || service.title} — ${img.tag || ''}`}
                            loading="lazy"
                            class="example-block__image"
                          />
                          {img.tag && (
                            <figcaption class="example-block__tag">{img.tag}</figcaption>
                          )}
                        </figure>
                      ))}
                    </div>
                  )}

                  {/* Fallback: any untagged or mis-tagged images that didn't
                      land in either collection — render them in a final grid
                      so nothing silently disappears */}
                  {categorised.other.length > 0 && (
                    <div class="example-block__images">
                      {categorised.other.map((img) => (
                        <figure class="example-block__figure">
                          <img
                            src={img.url}
                            alt={`${example.label || service.title} — ${img.tag || ''}`}
                            loading="lazy"
                            class="example-block__image"
                          />
                          {img.tag && (
                            <figcaption class="example-block__tag">{img.tag}</figcaption>
                          )}
                        </figure>
                      ))}
                    </div>
                  )}
                </>
              )}

              {/* ─── UNIFORM MODE — all images share one tag (e.g. SOYL pre-collage) ─── */}
              {categorised.mode === 'uniform' && (
                <div class="example-block__source-grid">
                  {categorised.images.map((img) => (
                    <figure class="example-block__source-figure">
                      <img
                        src={img.url}
                        alt={`${example.label || service.title} — ${img.tag || ''}`}
                        loading="lazy"
                        class="example-block__source-image"
                      />
                      {img.tag && (
                        <figcaption class="example-block__source-tag">{img.tag}</figcaption>
                      )}
                    </figure>
                  ))}
                </div>
              )}

              {/* ─── STANDARD MODE — existing photoreal services ─── */}
              {categorised.mode === 'standard' && categorised.original && (
                <div class="example-block__original">
                  <figure class="example-block__figure">
                    <img
                      src={categorised.original.url}
                      alt={`${example.label || service.title} — ${categorised.original.tag || ''}`}
                      loading="lazy"
                      class="example-block__image"
                    />
                    {categorised.original.tag && (
                      <figcaption class="example-block__tag">{categorised.original.tag}</figcaption>
                    )}
                  </figure>
                </div>
              )}

              {categorised.mode === 'standard' && categorised.rest.length > 0 && (
                <div class="example-block__images">
                  {categorised.rest.map((img) => (
                    <figure class="example-block__figure">
                      <img
                        src={img.url}
                        alt={`${example.label || service.title} — ${img.tag || ''}`}
                        loading="lazy"
                        class="example-block__image"
                      />
                      {img.tag && (
                        <figcaption class="example-block__tag">{img.tag}</figcaption>
                      )}
                    </figure>
                  ))}
                </div>
              )}

              {example.videos?.length > 0 && (
                <div class="example-block__videos">
                  {example.videos.map((vid) => (
                    <div class="example-block__video-wrap">
                      <div class="example-block__video-container">
                        <iframe
                          src={`https://www.youtube.com/embed/${vid.youtubeId}`}
                          title={vid.title || `${example.label} video`}
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                          allowfullscreen
                          loading="lazy"
                        ></iframe>
                      </div>
                      {vid.tag && (
                        <p class="example-block__video-tag">{vid.tag}</p>
                      )}
                    </div>
                  ))}
                </div>
              )}

              {example.audioTracks?.length > 0 && (
                <div class="example-block__audio-list">
                  {example.audioTracks.map((track) => (
                    <div class="example-block__audio-item">
                      {track.coverUrl && (
                        <img
                          src={track.coverUrl}
                          alt={track.title}
                          class="example-block__audio-cover"
                          loading="lazy"
                        />
                      )}
                      <div class="example-block__audio-info">
                        <p class="example-block__audio-title">{track.title}</p>
                        {track.duration && (
                          <span class="example-block__audio-duration">{track.duration}</span>
                        )}
                      </div>
                      {track.audioUrl && (
                        <audio controls preload="none" class="example-block__audio-player">
                          <source src={track.audioUrl} />
                        </audio>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </section>
    )}

    <!-- Pricing Strip — shows three pricing paths (only renders when service.digitalPrice is set) -->
    <PricingStrip service={serviceForWizard} />

    <!-- Print Pricing Table — detailed standalone print prices (only renders when service has printUpcharges) -->
    <PrintPricingTable service={serviceForWizard} />

    <!-- How It Works -->
    {service.steps?.length > 0 && (
      <section class="service-page__how-it-works">
        <h2 class="service-page__section-title">How It Works</h2>
        <ol class="service-page__steps">
          {service.steps.map((step, i) => (
            <li class="service-page__step">
              <span class="service-page__step-number">{i + 1}</span>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>
      </section>
    )}

    {service.importantNote && (
      <aside class="service-page__note">
        <strong>Please Note:</strong> {service.importantNote}
      </aside>
    )}

    {/* ── FAQs for this service ─────────────────────────────── */}
    {serviceFaqs?.length > 0 && (
      <section class="service-page__faqs">
        <h2 class="service-page__section-title">Frequently Asked Questions</h2>
        <div class="service-faqs">
          {serviceFaqs.map((faq) => {
            const anchor = slugifyQuestion(faq.question);
            return (
              <details class="service-faq" id={`faq-${anchor}`}>
                <summary class="service-faq__summary">
                  <span class="service-faq__question">{faq.question}</span>
                  <svg class="service-faq__chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="service-faq__answer">{faq.answer}</div>
              </details>
            );
          })}
        </div>
        <p class="service-faqs__more">
          <a href={`/faqs#service-${service.slug.current}`}>See all FAQs →</a>
        </p>
      </section>
    )}

    <!-- Commission Workflow -->
    {showCommissionWorkflow ? (
      <section class="service-page__commission" id="commission">
        <CommissionWorkflow client:load service={serviceForWizard} />
      </section>
    ) : (
      <section class="service-page__commission" id="commission">
        <div class="commission-paused">
          <h2>Commissions paused</h2>
          <p>
            We're not currently accepting new <strong>{service.title}</strong> commissions.
            Please <a href="/contact">get in touch</a> if you'd like to be notified when bookings reopen.
          </p>
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  /* ── Page container ─────────────────────── */
  .service-page {
    max-width: 1060px;
    margin: 0 auto;
    padding: 1rem 1.5rem 4rem;
  }

  /* ── Hero ────────────────────────────────── */
  .service-page__hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .service-page__hero-frame {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2rem;
    background: transparent;
  }

  .service-page__hero-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .service-page__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  .service-page__description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-muted, #a1a1aa);
    max-width: 640px;
    margin: 0 auto;
  }

  .service-page__price {
    margin: 1.25rem 0 0;
    font-family: 'Space Mono', monospace;
    font-size: 1rem;
    color: var(--text-muted, #a1a1aa);
  }

  .service-page__price strong {
    color: #F07828;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .service-page__extended {
    max-width: 700px;
    margin: 0 auto 2.5rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted, #a1a1aa);
    text-align: center;
  }

  .service-page__extended p {
    margin: 0 0 1rem;
  }

  /* ── Section titles ─────────────────────── */
  .service-page__section-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    text-align: center;
    margin: 0 0 1.75rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  /* ── Gallery / examples ─────────────────── */
  .service-page__gallery {
    margin-bottom: 3rem;
  }

  .example-block {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border, #27272a);
  }

  .example-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .example-block__label {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 1.25rem;
    text-align: center;
    color: var(--text, #fafafa);
  }

  /* ── Collage mode (SOYL): section titles and source photo grid ────── */
  .example-block__section-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text, #fafafa);
    margin: 1.5rem 0 1rem;
    text-align: center;
    opacity: 0.85;
  }

  /* Collections mode — labelled heading above each collection's sub-grid.
   * Slightly more prominent than section-title since these break up a longer
   * example block into two named groups (e.g. Modern Decades / Historical
   * Periods on Back In Time). */
  .example-block__collection-heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text, #fafafa);
    margin: 2rem 0 1.25rem;
    text-align: center;
    position: relative;
  }

  .example-block__collection-heading::before,
  .example-block__collection-heading::after {
    content: '';
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.15);
    vertical-align: middle;
    margin: 0 0.75rem;
  }

  .example-block__price-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #00BCD4;
    text-transform: none;
    letter-spacing: 0;
    margin-left: 0.25rem;
  }

  /* Uniform-mode source grid — fixed 3-column layout */
  .example-block .example-block__source-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
    width: 100%;
    max-width: 1060px;
    margin-left: auto;
    margin-right: auto;
  }

  .example-block .example-block__source-figure {
    margin: 0;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .example-block__source-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

