---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { COLLECTIONS } from '../../data/products';
---

<BaseLayout title="Bespoke Commission" description="Commission a completely unique piece of pop culture art. Choose your subject, style, and format. From £45.">

  <section class="bg-bg-secondary py-16 border-b border-edge-line">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <span class="font-mono text-xs text-hot-magenta uppercase tracking-widest">Your Way</span>
      <h1 class="section-heading mt-2 mb-4">Bespoke Commission</h1>
      <p class="font-dm text-mid-grey text-lg">Your vision, our craft. Tell us what you want and we'll create it.</p>
    </div>
  </section>

  <section class="colour-block-magenta py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <h2 class="font-montserrat text-3xl font-bold mb-4">How It Works</h2>
      <p class="font-dm text-lg leading-relaxed mb-6">Describe your vision — a person, a pet, a scene, a style — and we'll create a one-of-a-kind piece of pop culture art tailored to you. Choose from any of our 10 art styles, pick your size and format, and we'll handle the rest.</p>
      <p class="font-mono text-2xl font-bold">From £45</p>
    </div>
  </section>

  <section class="py-16 bg-bg-primary">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-montserrat text-2xl font-bold text-off-white mb-6 reveal">Brief Us</h2>
      <form id="commission-form" class="space-y-4 reveal">
        <input type="hidden" name="serviceType" value="bespoke" />
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Name *</label><input type="text" name="customerName" required class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-hot-magenta transition-colors" /></div>
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Email *</label><input type="email" name="customerEmail" required class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-hot-magenta transition-colors" /></div>
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Describe what you'd like us to create *</label><textarea name="brief" required rows="5" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-hot-magenta transition-colors resize-y" placeholder="E.g. A neon glow portrait of my dog in the style of a movie poster..."></textarea></div>
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Preferred art style</label>
          <select name="preferredStyle" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-hot-magenta transition-colors">
            <option value="">No preference</option>
            {COLLECTIONS.map((c) => <option value={c.slug}>{c.name}</option>)}
          </select>
        </div>
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Preferred format</label>
          <select name="preferredFormat" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-hot-magenta transition-colors">
            <option value="">No preference</option>
            <option value="canvas">Canvas</option>
            <option value="poster">Poster</option>
            <option value="digital">Digital Only</option>
          </select>
        </div>
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Budget range</label>
          <select name="budgetRange" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-hot-magenta transition-colors">
            <option value="under-50">Under £50</option>
            <option value="50-100">£50 — £100</option>
            <option value="100-200">£100 — £200</option>
            <option value="200-plus">£200+</option>
          </select>
        </div>
        <button type="submit" class="btn-magenta w-full text-center py-3">Submit Brief</button>
        <p id="form-message" class="font-dm text-sm text-center hidden"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('commission-form') as HTMLFormElement;
  const msg = document.getElementById('form-message');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch('/api/submit-commission', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const result = await res.json();
      if (msg) { msg.textContent = result.success ? result.message : result.error; msg.className = `font-dm text-sm text-center ${result.success ? 'text-green-400' : 'text-red-400'}`; msg.classList.remove('hidden'); }
      if (result.success) form.reset();
    } catch { if (msg) { msg.textContent = 'Something went wrong.'; msg.className = 'font-dm text-sm text-center text-red-400'; msg.classList.remove('hidden'); } }
  });
</script>
