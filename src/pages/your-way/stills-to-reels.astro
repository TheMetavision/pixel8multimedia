---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Stills to Reels" description="Transform static images into cinematic animations. Our signature service. From £35.">

  <section class="bg-bg-secondary py-16 border-b border-edge-line">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <span class="font-mono text-xs text-pixel-cyan uppercase tracking-widest">Your Way</span>
      <h1 class="section-heading mt-2 mb-4">Stills to Reels</h1>
      <p class="font-dm text-mid-grey text-lg">Transform your favourite static images into dynamic, cinematic animations.</p>
    </div>
  </section>

  <section class="colour-block-cyan py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-montserrat text-3xl font-bold mb-8 reveal">Pricing</h2>
      <div class="grid md:grid-cols-3 gap-6 reveal">
        {[
          { tier: 'Basic', price: '£35', desc: 'Single subject, subtle motion, 3-5 seconds' },
          { tier: 'Standard', price: '£55', desc: 'Multi-element, sound design, 5-10 seconds' },
          { tier: 'Premium', price: '£85+', desc: 'Full scene, cinematic quality, custom duration' },
        ].map((t) => (
          <div class="bg-black/10 rounded-lg p-6">
            <h3 class="font-montserrat text-xl font-bold mb-1">{t.tier}</h3>
            <p class="font-mono text-2xl font-bold mb-2">{t.price}</p>
            <p class="font-dm text-sm opacity-80">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-bg-primary">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-montserrat text-2xl font-bold text-off-white mb-6 reveal">Animate Your Image</h2>
      <form id="commission-form" class="space-y-4 reveal">
        <input type="hidden" name="serviceType" value="stills-to-reels" />
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Name *</label><input type="text" name="customerName" required class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pixel-cyan transition-colors" /></div>
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Email *</label><input type="email" name="customerEmail" required class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pixel-cyan transition-colors" /></div>
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Describe what you'd like animated *</label><textarea name="brief" required rows="4" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pixel-cyan transition-colors resize-y"></textarea></div>
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Animation style</label>
          <select name="preferredStyle" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pixel-cyan transition-colors">
            <option value="cinematic">Cinematic</option><option value="playful">Playful</option><option value="dramatic">Dramatic</option><option value="subtle">Subtle</option>
          </select>
        </div>
        <div><label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Duration preference</label>
          <select name="turnaround" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pixel-cyan transition-colors">
            <option value="3s">3 seconds</option><option value="5s">5 seconds</option><option value="10s">10 seconds</option><option value="custom">Custom</option>
          </select>
        </div>
        <button type="submit" class="btn-cyan w-full text-center py-3">Submit Request</button>
        <p id="form-message" class="font-dm text-sm text-center hidden"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('commission-form') as HTMLFormElement;
  const msg = document.getElementById('form-message');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch('/api/submit-commission', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const result = await res.json();
      if (msg) { msg.textContent = result.success ? result.message : result.error; msg.className = `font-dm text-sm text-center ${result.success ? 'text-green-400' : 'text-red-400'}`; msg.classList.remove('hidden'); }
      if (result.success) form.reset();
    } catch { if (msg) { msg.textContent = 'Something went wrong.'; msg.className = 'font-dm text-sm text-center text-red-400'; msg.classList.remove('hidden'); } }
  });
</script>
