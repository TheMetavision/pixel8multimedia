---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Photo Restoration" description="Professional AI-enhanced photo restoration. Repair faded, torn, or damaged photographs. From £25.">

  <section class="bg-bg-secondary py-16 border-b border-edge-line">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <span class="font-mono text-xs text-pop-orange uppercase tracking-widest">Your Way</span>
      <h1 class="section-heading mt-2 mb-4">Photo Restoration</h1>
      <p class="font-dm text-mid-grey text-lg">Breathe new life into treasured memories. AI-enhanced technology with human artistry.</p>
    </div>
  </section>

  <!-- What We Fix -->
  <section class="py-16 bg-bg-primary">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-montserrat text-2xl font-bold text-off-white mb-8 text-center reveal">What We Can Fix</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 reveal">
        {['Fading & Colour Loss', 'Tears & Damage', 'Missing Sections', 'Colour Correction', 'Scratches & Marks', 'Water Damage'].map((item) => (
          <div class="bg-bg-secondary border border-edge-line rounded-lg p-4 text-center">
            <span class="font-dm text-sm text-off-white">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="colour-block-orange py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-montserrat text-3xl font-bold mb-8 reveal">Pricing</h2>
      <div class="grid md:grid-cols-3 gap-6 reveal">
        {[
          { tier: 'Standard', price: '£25', desc: 'Minor fixes, colour correction, basic repair' },
          { tier: 'Advanced', price: '£45', desc: 'Significant damage repair, face restoration' },
          { tier: 'Full Reconstruction', price: '£75+', desc: 'Major rebuilds, missing elements, complex work' },
        ].map((t) => (
          <div class="bg-black/10 rounded-lg p-6">
            <h3 class="font-montserrat text-xl font-bold mb-1">{t.tier}</h3>
            <p class="font-mono text-2xl font-bold mb-2">{t.price}</p>
            <p class="font-dm text-sm opacity-80">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commission Form -->
  <section class="py-16 bg-bg-primary">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-montserrat text-2xl font-bold text-off-white mb-6 reveal">Start Your Restoration</h2>
      <form id="commission-form" class="space-y-4 reveal">
        <input type="hidden" name="serviceType" value="photo-restoration" />
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Name *</label>
          <input type="text" name="customerName" required class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pop-orange transition-colors" />
        </div>
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Email *</label>
          <input type="email" name="customerEmail" required class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pop-orange transition-colors" />
        </div>
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Phone</label>
          <input type="tel" name="customerPhone" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pop-orange transition-colors" />
        </div>
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Describe the damage *</label>
          <textarea name="brief" required rows="4" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pop-orange transition-colors resize-y"></textarea>
        </div>
        <div>
          <label class="font-montserrat text-xs font-semibold text-mid-grey uppercase tracking-wider block mb-1">Preferred turnaround</label>
          <select name="turnaround" class="w-full bg-bg-secondary border border-edge-line text-off-white font-dm text-sm px-4 py-3 rounded focus:outline-none focus:border-pop-orange transition-colors">
            <option value="standard">Standard (5-7 days)</option>
            <option value="priority">Priority (2-3 days)</option>
            <option value="rush">Rush (24 hours)</option>
          </select>
        </div>
        <button type="submit" class="btn-primary w-full text-center py-3">Submit Request</button>
        <p id="form-message" class="font-dm text-sm text-center hidden"></p>
        <p class="font-dm text-xs text-deep-grey text-center">We'll review your image and send a quote within 24 hours.</p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('commission-form') as HTMLFormElement;
  const msg = document.getElementById('form-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/submit-commission', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (msg) {
        msg.textContent = result.success ? result.message : result.error;
        msg.className = `font-dm text-sm text-center ${result.success ? 'text-green-400' : 'text-red-400'}`;
        msg.classList.remove('hidden');
      }
      if (result.success) form.reset();
    } catch {
      if (msg) {
        msg.textContent = 'Something went wrong. Please email us directly.';
        msg.className = 'font-dm text-sm text-center text-red-400';
        msg.classList.remove('hidden');
      }
    }
  });
</script>
