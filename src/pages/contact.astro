---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Pixel8 Multimedia. Questions about orders, personalised artwork, or anything else — we'd love to hear from you."
>
  <section class="relative bg-bg-secondary  py-16 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-pop-orange"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 50%, rgba(236,0,140,0.1) 0%, transparent 50%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <nav class="flex items-center gap-2 font-dm text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-pop-orange transition-colors">Home</a>
        <span>/</span>
        <span class="text-off-white">Contact</span>
      </nav>
      <div class=" inline-block mb-4">Say Hello!</div>
      <h1 class="font-montserrat font-bold text-5xl md:text-7xl text-off-white tracking-wide mb-4"
          style="text-shadow: 4px 4px 0 rgba(0,0,0,0.5);">
        GET IN <span class="text-pop-orange">TOUCH</span>
      </h1>
      <p class="font-dm text-gray-300 text-lg max-w-xl">
        We're a small, passionate team and we love hearing from our customers. Whether it's a question about an order, a custom request, or just to say hi — drop us a message.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <div class="flex justify-center mb-8">
          <img
            src="/Pixel8_Logo.png"
            alt="Pixel8 Multimedia"
            class="block"
            style="max-width: 280px; width: 100%; height: auto;"
          />
        </div>
        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block font-montserrat font-semibold text-off-white text-sm uppercase tracking-wide mb-2">Name *</label>
              <input
                type="text"
                name="name"
                required
                class="w-full bg-bg-secondary border-4 border-edge-line text-off-white px-4 py-3 font-dm focus:outline-none focus:border-pop-orange transition-colors placeholder:text-gray-600"
                placeholder="Your full name"
              />
            </div>
            <div>
              <label class="block font-montserrat font-semibold text-off-white text-sm uppercase tracking-wide mb-2">Email *</label>
              <input
                type="email"
                name="email"
                required
                class="w-full bg-bg-secondary border-4 border-edge-line text-off-white px-4 py-3 font-dm focus:outline-none focus:border-pop-orange transition-colors placeholder:text-gray-600"
                placeholder="your@email.com"
              />
            </div>
          </div>
          <div>
            <label class="block font-montserrat font-semibold text-off-white text-sm uppercase tracking-wide mb-2">Subject *</label>
            <select
              name="subject"
              required
              class="w-full bg-bg-secondary border-4 border-edge-line text-off-white px-4 py-3 font-dm focus:outline-none focus:border-pop-orange transition-colors"
            >
              <option value="" disabled selected>Choose a subject...</option>
              <option value="general">General Enquiry</option>
              <option value="custom">Custom Order</option>
              <option value="order-issue">Issue with Order</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label class="block font-montserrat font-semibold text-off-white text-sm uppercase tracking-wide mb-2">Message *</label>
            <textarea
              name="message"
              rows="6"
              required
              class="w-full bg-bg-secondary border-4 border-edge-line text-off-white px-4 py-3 font-dm focus:outline-none focus:border-pop-orange transition-colors placeholder:text-gray-600 resize-none"
              placeholder="Tell us everything..."
            ></textarea>
          </div>
          <div>
            <button type="submit" class="btn-primary text-xl">SEND MESSAGE</button>
          </div>
          <div id="contact-success" class="hidden bg-bg-secondary border-4 border-pop-orange p-4" style="box-shadow: 3px 3px 0 rgba(255,242,0,0.3);">
            <p class="font-montserrat font-semibold text-pop-orange uppercase tracking-wide text-sm">Message sent!</p>
            <p class="font-dm text-gray-300 text-sm mt-1">We'll get back to you within 24-48 hours.</p>
          </div>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="bg-bg-secondary border-4 border-edge-line p-6" style="box-shadow: 4px 4px 0 #000;">
          <h3 class="font-montserrat font-semibold text-pop-orange uppercase tracking-wide text-sm mb-4">Contact Info</h3>
          <div class="space-y-4">
            <div class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-hot-magenta flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-montserrat font-semibold text-off-white text-sm">Email</p>
                <a href="mailto:hello@pixel8multimedia.co.uk"
                   class="font-dm text-pixel-cyan hover:text-pop-orange transition-colors text-sm">
                  hello@pixel8multimedia.co.uk
                </a>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-hot-magenta flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-montserrat font-semibold text-off-white text-sm">Response Time</p>
                <p class="font-dm text-gray-400 text-sm">Within 24-48 hours</p>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-hot-magenta flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <div>
                <p class="font-montserrat font-semibold text-off-white text-sm">Based In</p>
                <p class="font-dm text-gray-400 text-sm">United Kingdom</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-bg-secondary border-4 border-edge-line p-6" style="box-shadow: 4px 4px 0 #000;">
          <h3 class="font-montserrat font-semibold text-pop-orange uppercase tracking-wide text-sm mb-4">Follow Us</h3>
          <div class="flex gap-3">
            <a href="#" class="w-10 h-10 bg-bg-primary border-2 border-pop-orange flex items-center justify-center hover:bg-pop-orange transition-colors">
              <svg class="w-5 h-5 text-off-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a href="#" class="w-10 h-10 bg-bg-primary border-2 border-pop-orange flex items-center justify-center hover:bg-pop-orange transition-colors">
              <svg class="w-5 h-5 text-off-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="#" class="w-10 h-10 bg-bg-primary border-2 border-pop-orange flex items-center justify-center hover:bg-pop-orange transition-colors">
              <svg class="w-5 h-5 text-off-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="bg-bg-secondary border-4 border-edge-line p-6" style="box-shadow: 4px 4px 0 #000;">
          <h3 class="font-montserrat font-semibold text-pop-orange uppercase tracking-wide text-sm mb-4">Quick Links</h3>
          <ul class="space-y-2">
            {[
              { label: 'Start a Custom Order', href: '/services' },
              { label: 'View Services & Pricing', href: '/services' },
              { label: 'Browse the Store', href: '/store' },
            ].map(link => (
              <li>
                <a href={link.href}
                   class="font-dm text-gray-400 hover:text-pop-orange transition-colors text-sm flex items-center gap-2">
                  <span class="w-1 h-1 bg-pop-orange rounded-full flex-shrink-0"></span>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const success = document.getElementById('contact-success');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.textContent = 'SENT!';
      btn.disabled = true;
      success?.classList.remove('hidden');
    });
  </script>
</BaseLayout>
