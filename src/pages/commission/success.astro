---
// src/pages/commission/success.astro
// Shown after successful Stripe Checkout for a commission order
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

const ref = Astro.url.searchParams.get('ref') || '';
---

<BaseLayout title="Order Confirmed — Pixel8 Multimedia" description="Your commission order has been placed successfully.">
  <main class="success-page">
    <div class="success-page__card">
      <div class="success-page__icon">✅</div>
      <h1 class="success-page__title">You're all set!</h1>
      {ref && (
        <p class="success-page__ref">
          Order reference: <strong>{ref}</strong>
        </p>
      )}
      <p class="success-page__message">
        Thanks for your order! We've received your brief and files and will get started shortly.
        You'll receive an email confirmation, and we'll notify you at each stage of progress.
      </p>
      <div class="success-page__timeline">
        <div class="success-page__step success-page__step--done">
          <span class="success-page__dot"></span>
          <span>Payment received</span>
        </div>
        <div class="success-page__step">
          <span class="success-page__dot"></span>
          <span>Work begins</span>
        </div>
        <div class="success-page__step">
          <span class="success-page__dot"></span>
          <span>Review &amp; final touches</span>
        </div>
        <div class="success-page__step">
          <span class="success-page__dot"></span>
          <span>Delivered to your inbox</span>
        </div>
      </div>
      <p class="success-page__contact">
        Questions? Email us at
        <a href="mailto:hello@pixel8multimedia.co.uk">hello@pixel8multimedia.co.uk</a>
      </p>
      <a href="/" class="success-page__cta">Back to Pixel8</a>
    </div>
  </main>
</BaseLayout>

<style>
  .success-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 2rem 1.5rem;
  }

  .success-page__card {
    max-width: 520px;
    width: 100%;
    text-align: center;
    padding: 3rem 2.5rem;
    background: #141418;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
  }

  .success-page__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .success-page__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    color: #F0EDE6;
  }

  .success-page__ref {
    font-size: 0.9375rem;
    color: #8A8A8E;
    margin: 0 0 1.5rem;
    font-family: 'Space Mono', monospace;
  }

  .success-page__ref strong {
    color: #F07828;
  }

  .success-page__message {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: #8A8A8E;
    margin: 0 0 2rem;
  }

  .success-page__timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    align-items: flex-start;
    max-width: 260px;
    margin: 0 auto 2rem;
    text-align: left;
  }

  .success-page__step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    padding: 0.625rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #8A8A8E;
  }

  .success-page__step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 5px;
    top: calc(50% + 10px);
    width: 2px;
    height: calc(100% - 4px);
    background: rgba(255, 255, 255, 0.1);
  }

  .success-page__dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.15);
    background: transparent;
  }

  .success-page__step--done .success-page__dot {
    background: #00BCD4;
    border-color: #00BCD4;
  }

  .success-page__step--done {
    color: #F0EDE6;
    font-weight: 600;
  }

  .success-page__contact {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #8A8A8E;
    margin: 0 0 1.5rem;
  }

  .success-page__contact a {
    color: #00BCD4;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .success-page__cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: #F07828;
    color: #000;
    text-decoration: none;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .success-page__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 20px rgba(240, 120, 40, 0.3);
  }
</style>
