---
// src/pages/commission/success.astro
// Shown after Stripe Checkout redirects back. Reflects the REAL order state
// rather than always claiming success: the payment webhook may not have
// recorded the order yet (timing), or the ref may be unknown. Only the order
// status is read here — no customer details — since the ref sits in the URL.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient } from '../../lib/sanity';

const ref = Astro.url.searchParams.get('ref') || '';

let state: 'confirmed' | 'pending' | 'unknown' = 'unknown';
let deliveryType = '';

if (ref) {
  try {
    const order = await sanityClient.fetch(
      `*[_type == "commission" && orderRef == $ref][0]{ status, deliveryType }`,
      { ref }
    );
    if (order) {
      deliveryType = order.deliveryType || '';
      // The doc is created at checkout as "pending"; the webhook flips it once
      // payment is recorded. Anything past "pending" means it's confirmed.
      state = order.status && order.status !== 'pending' ? 'confirmed' : 'pending';
    }
  } catch {
    // Lookup failed — payment itself happened at Stripe, so reassure rather
    // than error, but don't assert a confirmation we couldn't verify.
    state = 'pending';
  }
}

const posted = deliveryType === 'print' || deliveryType === 'both';
const finalStep = posted ? 'Finished & posted to you' : 'Finished & sent to your inbox';

const titleByState: Record<typeof state, string> = {
  confirmed: 'Order Confirmed — Pixel8 Multimedia',
  pending: 'Order Received — Pixel8 Multimedia',
  unknown: 'Order — Pixel8 Multimedia',
};
---

<BaseLayout title={titleByState[state]} description="Your Pixel8 commission order.">
  <main class="success-page">
    <div class="success-page__card">

      {state === 'confirmed' && (
        <>
          <div class="success-page__icon">✅</div>
          <h1 class="success-page__title">You're all set!</h1>
          {ref && <p class="success-page__ref">Order reference: <strong>{ref}</strong></p>}
          <p class="success-page__message">
            Thanks for your order! We've received your brief and files and we'll get started shortly.
            A confirmation email is on its way, and we'll let you know the moment your piece is ready.
          </p>
          <div class="success-page__timeline">
            <div class="success-page__step success-page__step--done"><span class="success-page__dot"></span><span>Payment received</span></div>
            <div class="success-page__step"><span class="success-page__dot"></span><span>We get to work</span></div>
            <div class="success-page__step"><span class="success-page__dot"></span><span>{finalStep}</span></div>
          </div>
        </>
      )}

      {state === 'pending' && (
        <>
          <div class="success-page__icon">⏳</div>
          <h1 class="success-page__title">Payment received</h1>
          {ref && <p class="success-page__ref">Order reference: <strong>{ref}</strong></p>}
          <p class="success-page__message">
            Thanks — your payment's gone through and we're just finalising your order.
            Your confirmation email will land shortly. This page will update on its own in a few seconds.
          </p>
          <div class="success-page__timeline">
            <div class="success-page__step success-page__step--done"><span class="success-page__dot"></span><span>Payment received</span></div>
            <div class="success-page__step"><span class="success-page__dot"></span><span>We get to work</span></div>
            <div class="success-page__step"><span class="success-page__dot"></span><span>{finalStep}</span></div>
          </div>
          <script is:inline define:vars={{ ref }}>
            // Upgrade to the confirmed view once the webhook lands. Capped so it
            // can't loop forever if the order genuinely stays unconfirmed.
            const key = 'px-suc-tries-' + ref;
            const tries = +(sessionStorage.getItem(key) || 0);
            if (tries < 3) {
              sessionStorage.setItem(key, tries + 1);
              setTimeout(() => location.reload(), 5000);
            }
          </script>
        </>
      )}

      {state === 'unknown' && (
        <>
          <div class="success-page__icon">📦</div>
          <h1 class="success-page__title">Thanks for your order</h1>
          {ref && <p class="success-page__ref">Order reference: <strong>{ref}</strong></p>}
          <p class="success-page__message">
            If you've just completed payment, your confirmation email is on its way.
            If you reached this page by mistake, or something doesn't look right, email us and we'll check it out.
          </p>
        </>
      )}

      <p class="success-page__contact">
        Questions? Email us at
        <a href="mailto:hello@pixel8multimedia.co.uk">hello@pixel8multimedia.co.uk</a>
      </p>
      <a href="/" class="success-page__cta">Back to Pixel8</a>
    </div>
  </main>
</BaseLayout>

<style>
  .success-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 2rem 1.5rem;
  }

  .success-page__card {
    max-width: 520px;
    width: 100%;
    text-align: center;
    padding: 3rem 2.5rem;
    background: #141418;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
  }

  .success-page__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .success-page__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    color: #F0EDE6;
  }

  .success-page__ref {
    font-size: 0.9375rem;
    color: #8A8A8E;
    margin: 0 0 1.5rem;
    font-family: 'Space Mono', monospace;
  }

  .success-page__ref strong {
    color: #F07828;
  }

  .success-page__message {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: #8A8A8E;
    margin: 0 0 2rem;
  }

  .success-page__timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    align-items: flex-start;
    max-width: 260px;
    margin: 0 auto 2rem;
    text-align: left;
  }

  .success-page__step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    padding: 0.625rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #8A8A8E;
  }

  .success-page__step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 5px;
    top: calc(50% + 10px);
    width: 2px;
    height: calc(100% - 4px);
    background: rgba(255, 255, 255, 0.1);
  }

  .success-page__dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.15);
    background: transparent;
  }

  .success-page__step--done .success-page__dot {
    background: #00BCD4;
    border-color: #00BCD4;
  }

  .success-page__step--done {
    color: #F0EDE6;
    font-weight: 600;
  }

  .success-page__contact {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #8A8A8E;
    margin: 0 0 1.5rem;
  }

  .success-page__contact a {
    color: #00BCD4;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .success-page__cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: #F07828;
    color: #000;
    text-decoration: none;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .success-page__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 20px rgba(240, 120, 40, 0.3);
  }
</style>
