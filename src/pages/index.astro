---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import { featuredProductsQuery, allCategoriesQuery, testimonialsQuery, faqsByPageQuery } from '../lib/queries';
import { PRICES, CATEGORIES, STYLES } from '../data/products';

let featuredProducts: any[] = [];
let categories: any[] = [];
let testimonials: any[] = [];
let faqs: any[] = [];

try {
  [featuredProducts, categories, testimonials, faqs] = await Promise.all([
    sanityClient.fetch(featuredProductsQuery),
    sanityClient.fetch(allCategoriesQuery),
    sanityClient.fetch(testimonialsQuery),
    sanityClient.fetch(faqsByPageQuery, { page: 'store' }),
  ]);
} catch (e) {
  console.warn('Sanity fetch failed, using fallback data');
  categories = CATEGORIES.map((c) => ({ ...c, productCount: 0 }));
}

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["Organization", "LocalBusiness"],
    "name": "Pixel8 Multimedia",
    "url": "https://pixel8multimedia.co.uk",
    "description": "UK-based pop culture wall art. Premium canvas prints, poster prints, photo restoration, and custom commissions.",
    "address": { "@type": "PostalAddress", "addressLocality": "Southend-on-Sea", "addressRegion": "Essex", "addressCountry": "GB" },
    "sameAs": ["https://facebook.com/pixel8multimedia", "https://instagram.com/pixel8multimedia", "https://x.com/pixel8multi", "https://tiktok.com/@pixel8multimedia"],
    "priceRange": "£9.99 - £200+"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Pixel8 Multimedia",
    "url": "https://pixel8multimedia.co.uk"
  }
];
---

<BaseLayout
  title="Pixel8 Multimedia — Premium Pop Culture Wall Art"
  description="Premium pop culture wall art and bespoke photo transformations. Canvas prints, poster prints, and custom commissions across 10+ art styles. UK-made, worldwide delivery."
  jsonLd={jsonLd}
>

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[90vh] flex items-center bg-bg-primary overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-bg-primary via-bg-secondary to-bg-primary"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <span class="font-mono text-xs text-pop-orange uppercase tracking-widest mb-4 block">UK Made · Worldwide Delivery</span>
        <h1 class="font-montserrat text-5xl md:text-6xl lg:text-7xl font-bold text-off-white leading-tight mb-6">
          Where Pop Culture Meets
          <span class="logo-gradient block">Pixel-Perfect Art</span>
        </h1>
        <p class="font-dm text-lg text-mid-grey leading-relaxed mb-8 max-w-xl">
          Bold pop culture wall art and bespoke AI photo transformation. Shop canvas prints or commission personalised artwork. UK & worldwide delivery.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/store" class="btn-primary">Shop Wall Art</a>
          <a href="/services" class="btn-secondary">Commission Yours</a>
        </div>
        <div class="flex items-center gap-6 mt-8 text-sm text-mid-grey font-dm">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-pop-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            500+ Artworks
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-pixel-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            10+ Styles
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-hot-magenta" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Made In-House
          </span>
        </div>
      </div>
      <div class="hidden lg:block reveal stagger-2">
        <div class="w-full aspect-[3/4] rounded-lg overflow-hidden border border-edge-line">
          <img src="/mockups/hero-artwork.png" alt="Pikachu Noir style wall art by Pixel8 Multimedia" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR WAY / YOUR WAY ===== -->
  <section class="py-20 bg-bg-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-8">
      <a href="/store" class="group bg-bg-secondary border border-edge-line rounded-lg overflow-hidden hover:border-pop-orange hover:shadow-glow-orange transition-all duration-300 reveal">
        <div class="aspect-[16/9] bg-bg-tertiary flex items-center justify-center overflow-hidden">
          <img src="/mockups/our-way-hero.png" alt="Pop culture wall art collection preview" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="p-6">
          <h2 class="font-montserrat text-2xl font-bold text-off-white mb-2">Our Way</h2>
          <p class="font-dm text-mid-grey text-sm leading-relaxed mb-4">Explore our pop culture wall art across 6 categories and 10 unique styles. Canvas prints and posters ready to ship.</p>
          <span class="font-montserrat text-sm font-bold text-pop-orange uppercase tracking-wider">Browse the Shop →</span>
        </div>
      </a>
      <a href="/services" class="group bg-bg-secondary border border-edge-line rounded-lg overflow-hidden hover:border-pixel-cyan hover:shadow-glow-cyan transition-all duration-300 reveal stagger-1">
        <div class="aspect-[16/9] bg-bg-tertiary flex items-center justify-center overflow-hidden">
          <img src="/mockups/your-way-hero.jpeg" alt="Custom personalised services preview" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="p-6">
          <h2 class="font-montserrat text-2xl font-bold text-off-white mb-2">Your Way</h2>
          <p class="font-dm text-mid-grey text-sm leading-relaxed mb-4">Commission something uniquely yours. Photo restoration, Stills to Reels animation, and bespoke artwork.</p>
          <span class="font-montserrat text-sm font-bold text-pixel-cyan uppercase tracking-wider">Start Your Project →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ===== CATEGORIES ===== -->
  <section class="py-20 bg-bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12 reveal">
        <div>
          <span class="font-mono text-xs text-pixel-cyan uppercase tracking-widest">6 Categories · 10 Styles</span>
          <h2 class="section-heading mt-2">Browse by Category</h2>
        </div>
        <a href="/store" class="font-montserrat text-sm font-bold text-pop-orange uppercase tracking-wider hover:underline hidden md:block">View All →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {(categories.length > 0 ? categories : CATEGORIES).map((cat: any, i: number) => (
          <a href={`/store?category=${cat.slug}`}
             class={`bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pop-orange transition-all duration-300 reveal stagger-${Math.min(i + 1, 4)}`}>
            <div class="aspect-[4/3] bg-bg-tertiary flex items-center justify-center">
              {cat.coverImage?.asset ? (
                <img src={urlFor(cat.coverImage).width(400).height(300).url()} alt={cat.name} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <span class="font-montserrat text-[0.6rem] text-deep-grey uppercase tracking-widest text-center px-2">{cat.name}</span>
              )}
            </div>
            <div class="p-3">
              <h3 class="font-montserrat text-sm font-bold text-off-white">{cat.name}</h3>
              <p class="font-dm text-xs text-deep-grey mt-0.5">{cat.tagline || cat.description}</p>
              {cat.productCount != null && <p class="font-mono text-xs text-pop-orange mt-1">{cat.productCount} designs</p>}
            </div>
          </a>
        ))}
      </div>
      <a href="/store" class="font-montserrat text-sm font-bold text-pop-orange uppercase tracking-wider hover:underline mt-6 block md:hidden">View All →</a>
    </div>
  </section>

  <!-- ===== MADE TO ORDER (Orange block) ===== -->
  <section class="colour-block-orange py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <h2 class="font-montserrat text-4xl md:text-5xl font-bold mb-6">Made to Order</h2>
          <p class="font-dm text-lg leading-relaxed mb-6">
            Every piece is crafted to stand out — designed for those who want their walls to tell a story. Each artwork is produced individually for you.
          </p>
          <div class="space-y-3 font-dm">
            <p><strong>Three sizes:</strong> Small (12×8" / 12×12") · Medium (16×12" / 16×16") · Large (24×16" / 20×20")</p>
            <p><strong>Three finishes:</strong> Poster Print · Canvas (Standard Frame) · Canvas (Gallery Frame)</p>
          </div>
          <a href="/store" class="inline-block mt-8 bg-black text-pop-orange font-montserrat font-bold text-sm uppercase tracking-wider px-8 py-3 hover:bg-bg-secondary transition-colors">Shop Now</a>
        </div>
        <div class="grid grid-cols-2 gap-4 reveal stagger-2">
          <div class="aspect-square rounded-lg overflow-hidden"><img src="/mockups/mockup-1.jpg" alt="Pop culture wall art in a gaming room" class="w-full h-full object-cover" loading="lazy" /></div>
          <div class="aspect-square rounded-lg overflow-hidden"><img src="/mockups/mockup-2.jpg" alt="Bob Marley wall art in a bedroom" class="w-full h-full object-cover" loading="lazy" /></div>
          <div class="aspect-square rounded-lg overflow-hidden"><img src="/mockups/mockup-3.jpg" alt="Pink Panther wall art in an office" class="w-full h-full object-cover" loading="lazy" /></div>
          <div class="aspect-square rounded-lg overflow-hidden"><img src="/mockups/mockup-4.jpg" alt="Hulk wall art in a living room" class="w-full h-full object-cover" loading="lazy" /></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PRICING (Cyan block) ===== -->
  <section class="colour-block-cyan py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <div class="aspect-[4/3] rounded-lg overflow-hidden">
            <img src="/mockups/studio.png" alt="Pixel8 Multimedia print studio" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
        <div class="reveal stagger-1">
          <h2 class="font-montserrat text-4xl md:text-5xl font-bold mb-8">Pricing</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-montserrat font-bold text-lg mb-2">Poster Prints</h3>
              <p class="font-mono text-sm">Small — £{PRICES.poster.small.toFixed(2)} · Medium — £{PRICES.poster.medium.toFixed(2)} · Large — £{PRICES.poster.large.toFixed(2)}</p>
            </div>
            <div>
              <h3 class="font-montserrat font-bold text-lg mb-2">Canvas (Standard Frame)</h3>
              <p class="font-mono text-sm">Small — £{PRICES.canvasStandard.small.toFixed(2)} · Medium — £{PRICES.canvasStandard.medium.toFixed(2)} · Large — £{PRICES.canvasStandard.large.toFixed(2)}</p>
            </div>
            <div>
              <h3 class="font-montserrat font-bold text-lg mb-2">Canvas (Gallery Frame)</h3>
              <p class="font-mono text-sm">Small — £{PRICES.canvasGallery.small.toFixed(2)} · Medium — £{PRICES.canvasGallery.medium.toFixed(2)} · Large — £{PRICES.canvasGallery.large.toFixed(2)}</p>
            </div>
          </div>
          <p class="font-dm text-sm mt-6 opacity-70">Free UK P&P on orders over £50. International shipping calculated at checkout.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED PRODUCTS ===== -->
  {featuredProducts.length > 0 && (
    <section class="py-20 bg-bg-primary">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-12 reveal">
          <div>
            <span class="font-mono text-xs text-hot-magenta uppercase tracking-widest">Fresh From the Studio</span>
            <h2 class="section-heading mt-2">Latest Drops</h2>
          </div>
          <a href="/store" class="font-montserrat text-sm font-bold text-pop-orange uppercase tracking-wider hover:underline hidden md:block">View All →</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {featuredProducts.map((product: any) => (
            <div class="reveal">
              <ProductCard product={product} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== SERVICES ===== -->
  <section class="py-20 bg-bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="font-mono text-xs text-pixel-cyan uppercase tracking-widest">Your Way</span>
        <h2 class="section-heading mt-2">Custom Services</h2>
        <p class="font-dm text-mid-grey text-lg max-w-2xl mx-auto mt-4">Your vision, our craft. Every piece is uniquely yours — choose digital delivery or premium print.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/services/cartoonify-me" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-hot-magenta hover:shadow-glow-magenta transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/cartoonify-me.png" alt="Cartoonify Me service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-hot-magenta transition-colors">Cartoonify Me!</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Turn your photo into a cartoon masterpiece — Simpsons, Anime, Pixar, and more.</p>
            <span class="font-mono text-xs text-hot-magenta uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/stills-to-reels" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pixel-cyan hover:shadow-glow-cyan transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/stills-to-reels.png" alt="Stills to Reels service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pixel-cyan transition-colors">Stills to Reels</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Transform static images into dynamic animations you can share, showcase, or keep forever.</p>
            <span class="font-mono text-xs text-pixel-cyan uppercase tracking-wider">Digital Only →</span>
          </div>
        </a>
        <a href="/services/the-missing-moment" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pop-orange hover:shadow-glow-orange transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/the-missing-moment.jpeg" alt="The Missing Moment service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pop-orange transition-colors">The Missing Moment</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Add someone special into an existing photo — a loved one who has passed, or a friend who missed your wedding.</p>
            <span class="font-mono text-xs text-pop-orange uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/past-perfect" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pop-orange hover:shadow-glow-orange transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/past-perfect.png" alt="Past Perfect service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pop-orange transition-colors">Past Perfect</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Restore treasured memories with professional photo repair and colourisation.</p>
            <span class="font-mono text-xs text-pop-orange uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/your-song-your-story" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pixel-cyan hover:shadow-glow-cyan transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/your-song-your-story.png" alt="Your Song Your Story service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pixel-cyan transition-colors">Your Song Your Story</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Turn memories, milestones, or inside jokes into an original song composed just for you.</p>
            <span class="font-mono text-xs text-pixel-cyan uppercase tracking-wider">Digital Only →</span>
          </div>
        </a>
        <a href="/services/story-of-your-life" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pixel-cyan hover:shadow-glow-cyan transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/story-of-your-life.jpeg" alt="Story Of Your Life service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pixel-cyan transition-colors">Story Of Your Life</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Transform a lifetime of photographs into one beautifully crafted cinematic story.</p>
            <span class="font-mono text-xs text-pixel-cyan uppercase tracking-wider">Digital Only →</span>
          </div>
        </a>
        <a href="/services/back-in-time" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-hot-magenta hover:shadow-glow-magenta transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/back-in-time.png" alt="Back in Time service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-hot-magenta transition-colors">Back in Time</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">See yourself evolve across eras — from the 1950s through to the 2000s.</p>
            <span class="font-mono text-xs text-hot-magenta uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/the-day-i-met" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pop-orange hover:shadow-glow-orange transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/the-day-i-met.jpeg" alt="The Day I Met service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pop-orange transition-colors">The Day I Met...</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">A cinematic image of you alongside your favourite celebrity or sports hero.</p>
            <span class="font-mono text-xs text-pop-orange uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/scene-stealer" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-hot-magenta hover:shadow-glow-magenta transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/scene-stealer.jpeg" alt="Scene Stealer service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-hot-magenta transition-colors">Scene Stealer</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Become the star of cinema's most iconic scenes with photorealistic precision.</p>
            <span class="font-mono text-xs text-hot-magenta uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/crayon-to-creation" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pop-orange hover:shadow-glow-orange transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/crayon-to-creation.png" alt="Crayon To Creation service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pop-orange transition-colors">Crayon To Creation</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Turn your child's drawings into polished, professional-quality artwork.</p>
            <span class="font-mono text-xs text-pop-orange uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/star-power" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-hot-magenta hover:shadow-glow-magenta transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/star-power.png" alt="Star Power service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-hot-magenta transition-colors">Star Power</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Turn your child or pet into the star of their very own blockbuster poster.</p>
            <span class="font-mono text-xs text-hot-magenta uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
        <a href="/services/prankz" class="bg-bg-primary border border-edge-line rounded-lg overflow-hidden hover:border-pixel-cyan hover:shadow-glow-cyan transition-all duration-300 group reveal">
          <div class="aspect-[16/9] overflow-hidden"><img src="/services/prankz.png" alt="Prankz service example" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>
          <div class="p-5">
            <h3 class="font-montserrat text-lg font-bold text-off-white mb-1 group-hover:text-pixel-cyan transition-colors">Prankz!</h3>
            <p class="font-dm text-sm text-mid-grey leading-relaxed mb-3">Prank your friends with images that look way too real to ignore. All in good fun.</p>
            <span class="font-mono text-xs text-pixel-cyan uppercase tracking-wider">Digital + Print →</span>
          </div>
        </a>
      </div>
      <div class="text-center mt-10">
        <a href="/services" class="btn-secondary">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- ===== FAQ (Magenta block) ===== -->
  {faqs.length > 0 && (
    <section class="colour-block-magenta py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-montserrat text-4xl md:text-5xl font-bold mb-8 reveal">FAQs</h2>
        <FAQAccordion faqs={faqs} dark={false} />
        <a href="/contact" class="inline-block mt-8 bg-black text-hot-magenta font-montserrat font-bold text-sm uppercase tracking-wider px-8 py-3 hover:bg-bg-secondary transition-colors reveal">Got a Question? →</a>
      </div>
    </section>
  )}

  <!-- ===== TESTIMONIALS ===== -->
  {testimonials.length > 0 && (
    <section class="py-20 bg-bg-primary">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 reveal">
          <h2 class="section-heading">What Our Customers Say</h2>
        </div>
        <TestimonialCarousel testimonials={testimonials} />
      </div>
    </section>
  )}

  <!-- ===== NEWSLETTER ===== -->
  <section class="py-20 bg-bg-secondary">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <NewsletterSignup />
    </div>
  </section>

</BaseLayout>
